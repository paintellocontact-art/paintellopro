<div class="register-wrapper">
  <div class="register-card">
    <div class="brand">
      <i class="fas fa-paint-roller"></i>
      <span>Paintello Pro</span>
    </div>
    <h3 style="margin-top:0;"><i class="fas fa-user-plus"></i> انضم إلى فريقنا المحترف</h3>

    <!-- Flash Messages -->
    <% if (success && success.length) { %>
      <% success.forEach(msg => { %>
        <div class="alert alert-success alert-dismissible fade show"><%= msg %></div>
      <% }) %>
    <% } %>
    <% if (error && error.length) { %>
      <% error.forEach(msg => { %>
        <div class="alert alert-danger alert-dismissible fade show"><%= msg %></div>
      <% }) %>
    <% } %>
    <% if (warning && warning.length) { %>
      <% warning.forEach(msg => { %>
        <div class="alert alert-warning alert-dismissible fade show"><%= msg %></div>
      <% }) %>
    <% } %>
    <% if (info && info.length) { %>
      <% info.forEach(msg => { %>
        <div class="alert alert-info alert-dismissible fade show"><%= msg %></div>
      <% }) %>
    <% } %>

    <form action="/auth/register-painter" method="POST" enctype="multipart/form-data" id="painterRegistrationForm">

      <!-- Personal Information -->
      <h3><i class="fas fa-user"></i> المعلومات الشخصية</h3>
      <div class="form-group">
        <i class="fas fa-user input-icon"></i>
        <input type="text" class="form-control" name="name" placeholder="الاسم الكامل" value="<%= oldInput.name || '' %>" required>
      </div>
      <div class="form-group">
        <i class="fas fa-phone input-icon"></i>
        <input type="tel" class="form-control" name="phone" placeholder="رقم الهاتف (05XXXXXXXX)" pattern="[0]{1}[5-7]{1}[0-9]{8}" value="<%= oldInput.phone || '' %>" required>
      </div>
      <div class="form-group">
        <i class="fas fa-envelope input-icon"></i>
        <input type="email" class="form-control" name="email" placeholder="البريد الإلكتروني" value="<%= oldInput.email || '' %>" required>
      </div>
      <div class="form-group">
        <i class="fas fa-lock input-icon"></i>
        <input type="password" class="form-control" name="password" placeholder="كلمة المرور (6 أحرف على الأقل)" required>
      </div>
      <div class="form-group">
        <i class="fas fa-lock input-icon"></i>
        <input type="password" class="form-control" name="confirmPassword" placeholder="تأكيد كلمة المرور" required>
      </div>

      <!-- Professional Information -->
      <h3><i class="fas fa-briefcase"></i> المعلومات المهنية</h3>
      <div class="form-group">
        <i class="fas fa-calendar input-icon"></i>
        <input type="number" class="form-control" name="experience" placeholder="سنوات الخبرة" min="0" max="50" value="<%= oldInput.experience || '' %>" required>
      </div>
      <div class="form-group">
        <i class="fas fa-money-bill input-icon"></i>
        <input type="number" class="form-control" name="pricePerSqm" placeholder="السعر لكل متر مربع (دج)" min="0" value="<%= oldInput.pricePerSqm || '' %>" required>
      </div>
      <div class="form-group">
        <label style="color: rgba(255,255,255,0.85); font-size: 0.9rem; margin-bottom: 6px; display: block;">التخصص *</label>
        <div class="specialization-checks">
          <label><input type="checkbox" name="specialization" value="interior" <%= (oldInput.specialization && oldInput.specialization.includes('interior')) ? 'checked' : '' %>> دهان داخلي</label>
          <label><input type="checkbox" name="specialization" value="exterior" <%= (oldInput.specialization && oldInput.specialization.includes('exterior')) ? 'checked' : '' %>> دهان خارجي</label>
          <label><input type="checkbox" name="specialization" value="commercial" <%= (oldInput.specialization && oldInput.specialization.includes('commercial')) ? 'checked' : '' %>> تجاري</label>
          <label><input type="checkbox" name="specialization" value="residential" <%= (oldInput.specialization && oldInput.specialization.includes('residential')) ? 'checked' : '' %>> سكني</label>
        </div>
      </div>

      <!-- Location Information -->
      <h3><i class="fas fa-map-marker-alt"></i> معلومات الموقع</h3>
      <div class="form-group">
        <i class="fas fa-map input-icon"></i>
        <select class="form-select" id="wilaya" name="wilaya" required>
          <option value="">اختر الولاية</option>
          <% wilayas.forEach(wilaya => { %>
            <option value="<%= wilaya.name %>" <%= (oldInput.wilaya === wilaya.name) ? 'selected' : '' %>><%= wilaya.name %> (<%= wilaya.number %>)</option>
          <% }); %>
        </select>
      </div>
      <div class="form-group">
        <i class="fas fa-hashtag input-icon"></i>
        <input type="number" class="form-control" id="wilayaNumber" name="wilayaNumber" placeholder="رقم الولاية" value="<%= oldInput.wilayaNumber || '' %>" readonly required>
      </div>
      <div class="form-group">
        <textarea class="form-control" name="address" rows="2" placeholder="العنوان الكامل" required><%= oldInput.address || '' %></textarea>
      </div>

      <!-- Verification -->
      <h3><i class="fas fa-id-card"></i> التحقق</h3>
      <div class="form-group file-upload">
        <input type="file" class="form-control" id="idCard" name="idCard" accept="image/*" required>
        <div style="font-size:0.8rem; opacity:0.7; margin-top:6px;">
          <i class="fas fa-info-circle"></i> صورة واضحة لبطاقة الهوية (max 2MB)
        </div>
      </div>
      <div class="alert alert-info" style="margin-top:10px;">
        <i class="fas fa-info-circle me-2"></i>
        <strong>عملية إرسال المحفظة:</strong> بعد التسجيل يمكنك إرسال صور أعمالك إلى فريق الإدارة.
      </div>

      <!-- Terms -->
      <div class="terms-check">
        <input type="checkbox" id="terms" required>
        <label for="terms">أوافق على <a href="/terms">الشروط</a> و <a href="/privacy">الخصوصية</a></label>
      </div>

      <button type="submit" class="btn-register">تقديم طلب الانضمام كدهان محترف</button>

      <div class="signin-link">
        هل لديك حساب؟ <a href="/auth/login-painter">سجل الدخول</a>
      </div>
    </form>
  </div>
</div>

<script>
  // Auto-dismiss alerts
  setTimeout(() => {
    document.querySelectorAll('.alert').forEach(alert => {
      const bsAlert = new bootstrap.Alert(alert);
      bsAlert.close();
    });
  }, 4000);

  // Wilaya number auto-fill
  document.getElementById('wilaya')?.addEventListener('change', function() {
    const selectedOption = this.options[this.selectedIndex];
    if (selectedOption.value) {
      const match = selectedOption.text.match(/\((\d+)\)/);
      if (match) {
        document.getElementById('wilayaNumber').value = match[1];
      }
    } else {
      document.getElementById('wilayaNumber').value = '';
    }
  });

  // GTM sign-up event
  document.getElementById('painterRegistrationForm').addEventListener('submit', function(e) {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      'event': 'ga4_sign_up',
      'user_wilaya': document.getElementById('wilaya').value,
      'painter_price_sqm': parseInt(document.getElementById('pricePerSqm').value) || 0,
      'painter_experience': parseInt(document.getElementById('experience').value) || 0,
      'painter_specialization': Array.from(document.querySelectorAll('input[name="specialization"]:checked'))
                                .map(cb => cb.value).join(', ')
    });
  });
</script>

