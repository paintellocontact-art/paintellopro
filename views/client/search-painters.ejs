<%- include('../partials/header', { title: 'Find Professional Painters' }) %>

<div class="container py-5">
    <div class="row">
        <div class="col-12">
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold text-primary mb-3">Find Professional Painters</h1>
                <p class="lead text-muted">Browse verified painters in your area and choose the perfect one for your project</p>
            </div>

            <!-- Search and Filters -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <form class="row g-3">
                        <div class="col-md-4">
                            <label for="wilaya" class="form-label">Wilaya</label>
                            <select class="form-select" id="wilaya" name="wilaya">
                                <option value="">All Wilayas</option>
                                <% wilayas.forEach(wilaya => { %>
                                <option value="<%= wilaya.name %>"><%= wilaya.name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="specialization" class="form-label">Specialization</label>
                            <select class="form-select" id="specialization" name="specialization">
                                <option value="">All Types</option>
                                <option value="interior">Interior Painting</option>
                                <option value="exterior">Exterior Painting</option>
                                <option value="commercial">Commercial</option>
                                <option value="residential">Residential</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="experience" class="form-label">Minimum Experience</label>
                            <select class="form-select" id="experience" name="experience">
                                <option value="">Any Experience</option>
                                <option value="1">1+ Years</option>
                                <option value="3">3+ Years</option>
                                <option value="5">5+ Years</option>
                                <option value="10">10+ Years</option>
                            </select>
                        </div>
                        <div class="col-12 text-center">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-search me-2"></i>Search Painters
                            </button>
                            <button type="reset" class="btn btn-outline-secondary ms-2">Reset</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Painters Grid -->
            <div class="row">
                <% if (painters && painters.length > 0) { %>
                    <% painters.forEach(painter => { %>
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm border-0 card-hover">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary rounded-circle p-3 me-3">
                                        <i class="fas fa-brush text-white"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-1"><%= painter.user ? painter.user.name : 'Professional Painter' %></h5>
                                        <p class="text-muted small mb-0">
                                            <i class="fas fa-map-marker-alt me-1"></i>
                                            <%= painter.wilaya || 'Algeria' %>
                                        </p>
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <div class="star-rating mb-2">
                                        <% for (let i = 1; i <= 5; i++) { %>
                                        <i class="fas fa-star <%= i <= (painter.rating || 0) ? 'text-warning' : 'text-muted' %>"></i>
                                        <% } %>
                                        <span class="ms-1 small text-muted">(<%= (painter.rating || 0).toFixed(1) %>)</span>
                                    </div>
                                    <p class="small text-muted mb-2">
                                        <i class="fas fa-briefcase me-1"></i>
                                        <%= painter.experience || 0 %> years experience
                                    </p>
                                    <% if (painter.specialization && painter.specialization.length > 0) { %>
                                    <div class="d-flex flex-wrap gap-1">
                                        <% painter.specialization.slice(0, 2).forEach(spec => { %>
                                        <span class="badge bg-light text-dark border"><%= spec %></span>
                                        <% }); %>
                                    </div>
                                    <% } %>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h4 class="text-primary mb-0"><%= painter.pricePerSqm || 0 %> DZD</h4>
                                        <small class="text-muted">per m²</small>
                                    </div>
                                    <div class="text-end">
                                        <% if (painter.availability !== false) { %>
                                        <span class="badge bg-success">Available</span>
                                        <% } else { %>
                                        <span class="badge bg-secondary">Busy</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 pt-0">
                                <div class="d-grid gap-2">
                                    <a href="/client/create-order?painter=<%= painter._id %>" class="btn btn-primary">
                                        <i class="fas fa-paint-roller me-2"></i>Hire Now
                                    </a>
                                    <a href="/painters/<%= painter._id %>" class="btn btn-outline-primary">
                                        <i class="fas fa-eye me-2"></i>View Profile
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                <div class="col-12 text-center py-5">
                    <i class="fas fa-search fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">No painters found</h4>
                    <p class="text-muted">Try adjusting your search criteria or check back later for new painters in your area.</p>
                    <a href="/painters" class="btn btn-primary">Clear Filters</a>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
