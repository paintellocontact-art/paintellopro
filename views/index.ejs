<%- include('partials/header', { title: 'Paintello Pro' }) %>

<style>
/* Modern Muula Style - Homepage */
:root {
    --primary-blue: #2C5F8A;
    --primary-green: #4A9B6E;
    --primary-light: #7AB2C8;
    --primary-dark: #1E405E;
    --text-dark: #2D3748;
    --text-gray: #718096;
    --bg-light: #F7FAFC;
    --bg-white: #FFFFFF;
    --border-light: #E2E8F0;
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 12px;
}

/* Language Switcher */
.language-switcher-modern {
    background: var(--bg-white);
    border-bottom: 1px solid var(--border-light);
    padding: 8px 0;
}

.language-switcher-modern .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
}

.language-buttons {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
}

.btn-lang {
    padding: 6px 18px;
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid var(--border-light);
    background: transparent;
    color: var(--text-gray);
}

.btn-lang.active {
    background: var(--primary-green);
    border-color: var(--primary-green);
    color: white;
}

.btn-lang:hover:not(.active) {
    border-color: var(--primary-green);
    color: var(--primary-green);
}

/* Hero Section */
.hero-modern {
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-light) 100%);
    position: relative;
    overflow: hidden;
    padding: 60px 0;
}

.hero-modern::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.05)" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
    background-size: cover;
    opacity: 0.3;
}

.hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 2;
}

.hero-grid {
    display: flex;
    align-items: center;
    gap: 60px;
    flex-wrap: wrap;
}

.hero-content {
    flex: 1;
    min-width: 280px;
}

.hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(10px);
    padding: 6px 16px;
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 500;
    color: white;
    margin-bottom: 24px;
}

.hero-title {
    font-size: 3rem;
    font-weight: 800;
    color: white;
    margin-bottom: 20px;
    line-height: 1.2;
}

.hero-title span {
    color: #FFD700;
}

.hero-description {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 32px;
    line-height: 1.6;
}

.hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
}

.btn-hero-primary {
    background: var(--primary-green);
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.btn-hero-primary:hover {
    background: #3D8A5E;
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    color: white;
}

.btn-hero-secondary {
    background: transparent;
    border: 2px solid white;
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.btn-hero-secondary:hover {
    background: white;
    color: var(--primary-blue);
    transform: translateY(-2px);
}

.trust-badges {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
}

.trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.85);
    font-size: 0.85rem;
}

.hero-image {
    flex: 1;
    text-align: center;
    min-width: 280px;
}

.hero-image img {
    max-width: 100%;
    max-height: 400px;
    filter: drop-shadow(var(--shadow-lg));
}

/* Stats Section */
.stats-modern {
    background: var(--bg-white);
    padding: 50px 0;
    border-bottom: 1px solid var(--border-light);
}

.stats-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 40px;
}

.stat-item {
    text-align: center;
}

.stat-number {
    font-size: 2rem;
    font-weight: 800;
    color: var(--primary-blue);
    display: block;
}

.stat-label {
    font-size: 0.85rem;
    color: var(--text-gray);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Map Section - Realistic Algeria Map */
.map-section-modern {
    padding: 80px 0;
    background: linear-gradient(135deg, #F7FAFC 0%, #FFFFFF 100%);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
}

.section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 48px;
}

.section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 16px;
}

.section-header p {
    font-size: 1rem;
    color: var(--text-gray);
}

.map-container {
    max-width: 900px;
    margin: 0 auto 40px;
    position: relative;
    text-align: center;
}

.algeria-map-svg {
    width: 100%;
    height: auto;
    filter: drop-shadow(var(--shadow-md));
    transition: all 0.3s ease;
    background: #F0FAF4;
    border-radius: var(--radius-lg);
    padding: 20px;
}

.algeria-map-svg:hover {
    filter: drop-shadow(var(--shadow-lg));
}

.map-marker {
    cursor: pointer;
    transition: transform 0.3s ease;
    animation: fadeInScale 0.5s ease forwards;
    opacity: 0;
    transform: scale(0);
}

.map-marker:hover {
    transform: scale(1.2);
}

.map-marker:nth-child(1) { animation-delay: 0.1s; }
.map-marker:nth-child(2) { animation-delay: 0.2s; }
.map-marker:nth-child(3) { animation-delay: 0.3s; }
.map-marker:nth-child(4) { animation-delay: 0.4s; }
.map-marker:nth-child(5) { animation-delay: 0.5s; }
.map-marker:nth-child(6) { animation-delay: 0.6s; }

@keyframes fadeInScale {
    to {
        opacity: 1;
        transform: scale(1);
    }
}

.pulse-ring {
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% {
        transform: scale(1);
        opacity: 0.8;
    }
    100% {
        transform: scale(2);
        opacity: 0;
    }
}

.map-legend {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 24px;
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text-gray);
}

.legend-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
}

.legend-dot.active {
    background: #2C5F8A;
    box-shadow: 0 0 0 3px rgba(44, 95, 138, 0.2);
}

.legend-dot.moderate {
    background: #7AB2C8;
}

.legend-dot.low {
    background: #B8D4E3;
}

.map-stats-grid {
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
}

.map-stat-card {
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
    border: 1px solid var(--border-light);
}

.map-stat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
}

.map-stat-card i {
    font-size: 2rem;
    color: var(--primary-green);
}

.map-stat-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--primary-blue);
    display: block;
    line-height: 1;
}

.map-stat-label {
    font-size: 0.8rem;
    color: var(--text-gray);
}

/* How It Works */
.how-it-works-modern {
    padding: 80px 0;
    background: var(--bg-light);
}

.steps-grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
}

.step-card-modern {
    text-align: center;
    padding: 32px 24px;
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
    box-shadow: var(--shadow-sm);
}

.step-card-modern:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
}

.step-icon-wrapper {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--primary-blue), var(--primary-light));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
}

.step-icon-wrapper i {
    font-size: 2rem;
    color: white;
}

.step-number-modern {
    width: 32px;
    height: 32px;
    background: var(--primary-green);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    font-weight: 700;
    font-size: 0.85rem;
}

.step-card-modern h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 12px;
}

.step-card-modern p {
    color: var(--text-gray);
    line-height: 1.5;
    font-size: 0.9rem;
}

/* Featured Painters */
.featured-modern {
    padding: 80px 0;
    background: var(--bg-white);
}

.section-header-with-link {
    max-width: 1200px;
    margin: 0 auto 40px;
    padding: 0 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
}

.section-header-with-link h2 {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 8px;
}

.section-header-with-link p {
    color: var(--text-gray);
    margin: 0;
}

.view-all-link {
    color: var(--primary-green);
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
    padding: 8px 16px;
    border-radius: 40px;
    background: #F0FAF4;
}

.view-all-link:hover {
    gap: 12px;
    background: var(--primary-green);
    color: white;
}

.painters-grid-home {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
}

.painter-card-home {
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-light);
    cursor: pointer;
}

.painter-card-home:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
}

.card-body-home {
    padding: 24px;
    text-align: center;
}

.avatar-home {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    margin: 0 auto 16px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--primary-blue), var(--primary-light));
    display: flex;
    align-items: center;
    justify-content: center;
}

.avatar-home img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.avatar-home i {
    font-size: 2rem;
    color: white;
}

.verified-badge-home {
    position: absolute;
    bottom: 0;
    right: 0;
    background: var(--primary-green);
    border-radius: 50%;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--bg-white);
}

.verified-badge-home i {
    font-size: 0.65rem;
    color: white;
}

.painter-name-home {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 4px;
}

.painter-location-home {
    font-size: 0.8rem;
    color: var(--text-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    margin-bottom: 16px;
}

.stats-home {
    display: flex;
    justify-content: center;
    gap: 24px;
    padding: 12px 0;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 16px;
}

.stat-home {
    text-align: center;
}

.stat-value-home {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--primary-blue);
    display: block;
}

.stat-label-home {
    font-size: 0.65rem;
    color: var(--text-gray);
    text-transform: uppercase;
}

.rating-home {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 12px;
}

.rating-home i {
    font-size: 0.75rem;
}

.price-home {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--primary-green);
    margin-bottom: 16px;
}

.btn-profile-home {
    width: 100%;
    padding: 10px;
    background: transparent;
    border: 1px solid var(--border-light);
    border-radius: 40px;
    font-weight: 500;
    color: var(--text-dark);
    transition: all 0.3s ease;
    cursor: pointer;
}

.btn-profile-home:hover {
    border-color: var(--primary-green);
    background: #F0FAF4;
    color: var(--primary-green);
}

/* CTA Section */
.cta-modern {
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-light) 100%);
    padding: 80px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
}

.cta-modern::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.03)" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat top;
    background-size: cover;
}

.cta-container {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 2;
}

.cta-modern h2 {
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin-bottom: 16px;
}

.cta-modern p {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 32px;
}

.cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
}

.btn-cta-light {
    background: white;
    color: var(--primary-blue);
    padding: 14px 32px;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.btn-cta-light:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.btn-cta-outline {
    background: transparent;
    border: 2px solid white;
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.btn-cta-outline:hover {
    background: white;
    color: var(--primary-blue);
    transform: translateY(-2px);
}

/* Responsive */
@media (max-width: 768px) {
    .hero-title {
        font-size: 2rem;
    }
    
    .hero-description {
        font-size: 1rem;
    }
    
    .hero-grid {
        gap: 40px;
        text-align: center;
    }
    
    .hero-buttons {
        justify-content: center;
    }
    
    .trust-badges {
        justify-content: center;
    }
    
    .section-header h2 {
        font-size: 1.6rem;
    }
    
    .steps-grid {
        grid-template-columns: 1fr;
        gap: 20px;
    }
    
    .painters-grid-home {
        grid-template-columns: 1fr;
    }
    
    .section-header-with-link {
        flex-direction: column;
        text-align: center;
    }
    
    .stats-container {
        gap: 25px;
    }
    
    .stat-number {
        font-size: 1.5rem;
    }
    
    .cta-modern h2 {
        font-size: 1.5rem;
    }
    
    .language-buttons {
        justify-content: center;
    }
    
    .map-stats-grid {
        grid-template-columns: 1fr;
        padding: 0 20px;
    }
    
    .map-legend {
        gap: 16px;
    }
    
    .legend-item {
        font-size: 0.7rem;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .painters-grid-home {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.hero-content, .hero-image, .step-card-modern, .painter-card-home {
    animation: fadeInUp 0.6s ease forwards;
}

.step-card-modern:nth-child(1) { animation-delay: 0.1s; }
.step-card-modern:nth-child(2) { animation-delay: 0.2s; }
.step-card-modern:nth-child(3) { animation-delay: 0.3s; }
.step-card-modern:nth-child(4) { animation-delay: 0.4s; }
</style>

