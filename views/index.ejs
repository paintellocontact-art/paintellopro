<section class="map-section-modern">
    <div class="container">
        <div class="section-header">
            <h2>Painters Across Algeria</h2>
            <p>Our network of professional painters covers all 58 wilayas</p>
        </div>
        
        <div class="map-container">
            <!-- SVG Map of Algeria - Simplified but recognizable shape -->
            <svg viewBox="0 0 800 600" class="algeria-map-svg">
                <!-- Background -->
                <rect width="800" height="600" fill="#F0FAF4" rx="16"/>
                
                <!-- Algeria Outline - More accurate shape -->
                <!-- North Coast -->
                <path d="M 120 180 Q 150 160 180 150 Q 220 135 260 130 Q 300 125 340 130 
                         Q 380 135 420 130 Q 460 125 500 130 Q 540 135 580 140 
                         Q 620 150 660 160 Q 680 170 690 180" 
                      fill="none" stroke="#4A9B6E" stroke-width="2.5"/>
                
                <!-- Main landmass -->
                <path d="M 120 180 
                         Q 130 210 135 240 Q 140 270 150 300 
                         Q 160 340 175 370 Q 190 400 210 420 
                         Q 230 440 260 450 Q 290 460 320 465 
                         Q 360 470 400 465 Q 440 460 470 445 
                         Q 500 430 520 410 Q 540 380 550 350 
                         Q 560 320 565 290 Q 570 260 575 230 
                         Q 580 200 585 180 
                         L 690 180 
                         Q 680 200 670 230 Q 660 260 650 290 
                         Q 640 320 620 350 Q 600 370 580 380 
                         Q 560 390 540 395 Q 520 400 500 410 
                         Q 480 420 460 435 Q 440 450 410 460 
                         Q 380 470 340 475 Q 300 478 260 470 
                         Q 220 460 190 440 Q 165 420 150 390 
                         Q 135 360 130 330 Q 125 300 120 270 
                         Q 115 240 120 210 Z" 
                      fill="#E8F5E9" stroke="#4A9B6E" stroke-width="2"/>
                
                <!-- Desert region hint -->
                <path d="M 200 350 Q 250 340 300 350 Q 350 360 400 350 
                         Q 450 340 500 350 Q 550 360 580 370" 
                      fill="none" stroke="#C5E0B4" stroke-width="1.5" stroke-dasharray="4,4"/>
                
                <!-- Markers with painter counts -->
                <!-- Algiers -->
                <circle cx="340" cy="170" r="14" fill="#2C5F8A" class="map-marker" data-wilaya="Algiers"/>
                <text x="340" y="166" text-anchor="middle" fill="white" font-size="9" font-weight="bold">128</text>
                <text x="340" y="195" text-anchor="middle" fill="#2C5F8A" font-size="10" font-weight="600">Algiers</text>
                <circle cx="340" cy="170" r="22" fill="none" stroke="#4A9B6E" stroke-width="1.5" class="pulse-ring"/>
                
                <!-- Oran -->
                <circle cx="220" cy="240" r="12" fill="#2C5F8A" class="map-marker" data-wilaya="Oran"/>
                <text x="220" y="236" text-anchor="middle" fill="white" font-size="8" font-weight="bold">86</text>
                <text x="220" y="265" text-anchor="middle" fill="#2C5F8A" font-size="10" font-weight="600">Oran</text>
                <circle cx="220" cy="240" r="19" fill="none" stroke="#4A9B6E" stroke-width="1.5" class="pulse-ring"/>
                
                <!-- Constantine -->
                <circle cx="530" cy="210" r="11" fill="#2C5F8A" class="map-marker" data-wilaya="Constantine"/>
                <text x="530" y="206" text-anchor="middle" fill="white" font-size="8" font-weight="bold">64</text>
                <text x="530" y="235" text-anchor="middle" fill="#2C5F8A" font-size="10" font-weight="600">Constantine</text>
                <circle cx="530" cy="210" r="18" fill="none" stroke="#4A9B6E" stroke-width="1.5" class="pulse-ring"/>
                
                <!-- Annaba -->
                <circle cx="620" cy="220" r="10" fill="#7AB2C8" class="map-marker" data-wilaya="Annaba"/>
                <text x="620" y="216" text-anchor="middle" fill="white" font-size="7" font-weight="bold">42</text>
                <text x="620" y="245" text-anchor="middle" fill="#2C5F8A" font-size="9" font-weight="600">Annaba</text>
                
                <!-- Tizi Ouzou -->
                <circle cx="410" cy="145" r="9" fill="#7AB2C8" class="map-marker" data-wilaya="Tizi Ouzou"/>
                <text x="410" y="141" text-anchor="middle" fill="white" font-size="7" font-weight="bold">38</text>
                <text x="410" y="170" text-anchor="middle" fill="#2C5F8A" font-size="9" font-weight="600">Tizi Ouzou</text>
                
                <!-- Bejaia -->
                <circle cx="460" cy="170" r="9" fill="#7AB2C8" class="map-marker" data-wilaya="Bejaia"/>
                <text x="460" y="166" text-anchor="middle" fill="white" font-size="7" font-weight="bold">35</text>
                <text x="460" y="195" text-anchor="middle" fill="#2C5F8A" font-size="9" font-weight="600">Bejaia</text>
                
                <!-- Setif -->
                <circle cx="490" cy="260" r="8" fill="#7AB2C8" class="map-marker" data-wilaya="Setif"/>
                <text x="490" y="256" text-anchor="middle" fill="white" font-size="6" font-weight="bold">52</text>
                <text x="490" y="280" text-anchor="middle" fill="#2C5F8A" font-size="9" font-weight="600">Setif</text>
                
                <!-- Blida -->
                <circle cx="300" cy="200" r="7" fill="#B8D4E3" class="map-marker" data-wilaya="Blida"/>
                <text x="300" y="196" text-anchor="middle" fill="white" font-size="6" font-weight="bold">29</text>
                <text x="300" y="220" text-anchor="middle" fill="#2C5F8A" font-size="9" font-weight="600">Blida</text>
                
                <!-- Tlemcen -->
                <circle cx="155" cy="280" r="7" fill="#B8D4E3" class="map-marker" data-wilaya="Tlemcen"/>
                <text x="155" y="276" text-anchor="middle" fill="white" font-size="6" font-weight="bold">31</text>
                <text x="155" y="300" text-anchor="middle" fill="#2C5F8A" font-size="9" font-weight="600">Tlemcen</text>
                
                <!-- Batna -->
                <circle cx="480" cy="320" r="7" fill="#B8D4E3" class="map-marker" data-wilaya="Batna"/>
                <text x="480" y="316" text-anchor="middle" fill="white" font-size="6" font-weight="bold">27</text>
                <text x="480" y="340" text-anchor="middle" fill="#2C5F8A" font-size="9" font-weight="600">Batna</text>
            </svg>
            
            <!-- Map Legend -->
            <div class="map-legend">
                <div class="legend-item">
                    <div class="legend-dot active"></div>
                    <span>Active Painters (50+)</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot moderate"></div>
                    <span>Moderate (20-50)</span>
                </div>
                <div class="legend-item">
                    <div class="legend-dot low"></div>
                    <span>Growing (under 20)</span>
                </div>
            </div>
        </div>
        
        <!-- Map Stats Cards -->
        <div class="map-stats-grid">
            <div class="map-stat-card">
                <i class="fas fa-city"></i>
                <div>
                    <span class="map-stat-number">58</span>
                    <span class="map-stat-label">Wilayas Covered</span>
                </div>
            </div>
            <div class="map-stat-card">
                <i class="fas fa-users"></i>
                <div>
                    <span class="map-stat-number">500+</span>
                    <span class="map-stat-label">Active Painters</span>
                </div>
            </div>
            <div class="map-stat-card">
                <i class="fas fa-chart-line"></i>
                <div>
                    <span class="map-stat-number">100%</span>
                    <span class="map-stat-label">Nationwide Coverage</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="how-it-works-modern">
    <div class="section-header">
        <h2>How Paintello Pro Works</h2>
        <p>Simple steps to get your painting project done with zero hassle</p>
    </div>
    <div class="steps-grid">
        <div class="step-card-modern">
            <div class="step-number-modern">1</div>
            <div class="step-icon-wrapper">
                <i class="fas fa-search"></i>
            </div>
            <h3>Search Painters</h3>
            <p>Find verified painters in your wilaya with ratings and portfolios</p>
        </div>
        <div class="step-card-modern">
            <div class="step-number-modern">2</div>
            <div class="step-icon-wrapper">
                <i class="fas fa-clipboard-list"></i>
            </div>
            <h3>Create Order</h3>
            <p>Describe your project, set budget, and choose your preferred painter</p>
        </div>
        <div class="step-card-modern">
            <div class="step-number-modern">3</div>
            <div class="step-icon-wrapper">
                <i class="fas fa-paint-roller"></i>
            </div>
            <h3>Get It Painted</h3>
            <p>Professional painters complete your project with quality materials</p>
        </div>
        <div class="step-card-modern">
            <div class="step-number-modern">4</div>
            <div class="step-icon-wrapper">
                <i class="fas fa-star"></i>
            </div>
            <h3>Rate & Review</h3>
            <p>Share your experience and help maintain quality standards</p>
        </div>
    </div>
</section>

<!-- Featured Painters -->
<section class="featured-modern">
    <div class="section-header-with-link">
        <div>
            <h2>Featured Painters</h2>
            <p>Top-rated professionals in your area</p>
        </div>
        <a href="/painters" class="view-all-link">
            View All Painters <i class="fas fa-arrow-right"></i>
        </a>
    </div>
    
    <div class="painters-grid-home">
        <% featuredPainters.forEach(painter => { %>
        <div class="painter-card-home" onclick="window.location.href='/painters/<%= painter._id %>'">
            <div class="card-body-home">
                <div class="avatar-home">
                    <% if (painter.profilePicture && painter.profilePicture.url) { %>
                        <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>">
                    <% } else { %>
                        <i class="fas fa-brush"></i>
                    <% } %>
                    <% if (painter.verification?.status === 'verified') { %>
                        <div class="verified-badge-home">
                            <i class="fas fa-check"></i>
                        </div>
                    <% } %>
                </div>
                <div class="painter-name-home"><%= painter.name %></div>
                <div class="painter-location-home">
                    <i class="fas fa-map-marker-alt"></i> <%= painter.location?.wilaya || 'Algeria' %>
                </div>
                <div class="stats-home">
                    <div class="stat-home">
                        <span class="stat-value-home"><%= painter.experience || 0 %></span>
                        <span class="stat-label-home">Years</span>
                    </div>
                    <div class="stat-home">
                        <span class="stat-value-home"><%= painter.completedJobs || 0 %></span>
                        <span class="stat-label-home">Jobs</span>
                    </div>
                </div>
                <div class="rating-home">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star <%= i <= Math.round(painter.rating || 0) ? 'text-warning' : 'text-muted' %>" style="color: <%= i <= Math.round(painter.rating || 0) ? '#FBBF24' : '#E2E8F0' %>;"></i>
                    <% } %>
                    <span style="font-size: 0.7rem; color: var(--text-gray); margin-left: 4px;">(<%= (painter.rating || 0).toFixed(1) %>)</span>
                </div>
                <div class="price-home">
                    <%= painter.pricePerSqm || 0 %> DA/m²
                </div>
                <button class="btn-profile-home" onclick="event.stopPropagation(); window.location.href='/painters/<%= painter._id %>'">
                    View Profile
                </button>
            </div>
        </div>
        <% }); %>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-modern">
    <div class="cta-container">
        <h2>Ready to Start Your Painting Project?</h2>
        <p>Join thousands of satisfied customers who found their perfect painter through Paintello Pro</p>
        <div class="cta-buttons">
            <a href="/auth/register" class="btn-cta-light">
                <i class="fas fa-user-plus"></i> Get Started as Client
            </a>
            <a href="/auth/register-painter" class="btn-cta-outline">
                <i class="fas fa-brush"></i> Join as Painter
            </a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
