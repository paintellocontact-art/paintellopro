<%- include('../partials/header', { title: 'Find Painters - Paintello Pro' }) %>

<style>
/* Muula/Modern Style */
:root {
    --primary-blue: #2C5F8A;
    --primary-green: #4A9B6E;
    --primary-light: #7AB2C8;
    --text-dark: #2D3748;
    --text-gray: #718096;
    --bg-light: #F7FAFC;
    --bg-white: #FFFFFF;
    --border-light: #E2E8F0;
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.05);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
    --radius-lg: 20px;
    --radius-md: 16px;
    --radius-sm: 12px;
}

body {
    background: var(--bg-light);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

/* Hero Section - Modern Header */
.painters-hero {
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-light) 100%);
    padding: 48px 0;
    margin-bottom: 32px;
    border-radius: 0 0 30px 30px;
}

.hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
}

.hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 12px;
}

.hero-subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 32px;
}

/* Modern Search Bar */
.search-bar-modern {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
}

.search-bar-modern input {
    width: 100%;
    padding: 16px 24px;
    padding-left: 52px;
    border: none;
    border-radius: 50px;
    font-size: 1rem;
    box-shadow: var(--shadow-lg);
    background: var(--bg-white);
    transition: all 0.3s ease;
}

.search-bar-modern input:focus {
    outline: none;
    box-shadow: 0 8px 28px rgba(0,0,0,0.15);
    transform: translateY(-2px);
}

.search-bar-modern i {
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-gray);
    font-size: 1.1rem;
}

/* Filter Chips - Modern Style */
.filter-section {
    max-width: 1200px;
    margin: 0 auto 32px;
    padding: 0 24px;
}

.filter-chips-modern {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
}

.chip {
    padding: 10px 20px;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: 40px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-dark);
    cursor: pointer;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.chip i {
    font-size: 0.9rem;
    color: var(--text-gray);
}

.chip:hover {
    border-color: var(--primary-green);
    background: #F0FAF4;
    transform: translateY(-2px);
}

.chip.active {
    background: var(--primary-green);
    border-color: var(--primary-green);
    color: white;
}

.chip.active i {
    color: white;
}

/* Results Header */
.results-header {
    max-width: 1200px;
    margin: 0 auto 24px;
    padding: 0 24px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 16px;
}

.results-count h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 4px;
}

.results-count p {
    color: var(--text-gray);
    font-size: 0.9rem;
    margin: 0;
}

.sort-modern select {
    padding: 10px 16px;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    background: var(--bg-white);
    font-size: 0.9rem;
    color: var(--text-dark);
    cursor: pointer;
    transition: all 0.2s ease;
}

.sort-modern select:hover {
    border-color: var(--primary-green);
}

/* Painter Cards - Muula Style */
.painters-grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 48px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 28px;
}

.painter-card-muula {
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    position: relative;
}

.painter-card-muula:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
}

/* Card Cover */
.card-cover-muula {
    height: 140px;
    background: linear-gradient(135deg, var(--primary-blue), var(--primary-light));
    position: relative;
    overflow: hidden;
}

.card-cover-muula img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Avatar */
.avatar-muula {
    position: absolute;
    bottom: -35px;
    left: 20px;
    width: 70px;
    height: 70px;
    border-radius: 50%;
    border: 4px solid var(--bg-white);
    background: var(--bg-white);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
}

.avatar-muula img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.verified-badge-muula {
    position: absolute;
    bottom: -2px;
    right: -2px;
    background: var(--primary-green);
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--bg-white);
}

.verified-badge-muula i {
    font-size: 0.6rem;
    color: white;
}

/* Card Body */
.card-body-muula {
    padding: 48px 20px 20px;
}

.painter-name-muula {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
}

.location-muula {
    font-size: 0.8rem;
    color: var(--text-gray);
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 16px;
}

/* Stats Row */
.stats-row-muula {
    display: flex;
    gap: 20px;
    padding: 12px 0;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 16px;
}

.stat-item-muula {
    text-align: center;
    flex: 1;
}

.stat-value-muula {
    font-size: 1rem;
    font-weight: 700;
    color: var(--primary-blue);
    display: block;
}

.stat-label-muula {
    font-size: 0.7rem;
    color: var(--text-gray);
}

/* Rating Stars */
.rating-muula {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
}

.stars-muula {
    display: flex;
    gap: 2px;
}

.stars-muula i {
    font-size: 0.8rem;
}

.rating-number-muula {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-dark);
}

/* Specialties */
.specialties-muula {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
}

.specialty-tag-muula {
    font-size: 0.7rem;
    padding: 4px 12px;
    background: var(--bg-light);
    border-radius: 20px;
    color: var(--text-dark);
}

/* Price Section */
.price-section-muula {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.price-muula {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary-green);
}

.price-muula small {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--text-gray);
}

.availability-muula {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
}

.availability-muula.available {
    background: #E6F7EC;
    color: var(--primary-green);
}

.availability-muula.busy {
    background: #FEF3E2;
    color: #E67E22;
}

/* Action Buttons */
.actions-muula {
    display: flex;
    gap: 12px;
}

.btn-muula {
    flex: 1;
    padding: 10px;
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    border: none;
    font-family: inherit;
}

.btn-muula-primary {
    background: var(--primary-green);
    color: white;
}

.btn-muula-primary:hover {
    background: #3D8A5E;
    transform: translateY(-2px);
}

.btn-muula-secondary {
    background: transparent;
    border: 1px solid var(--border-light);
    color: var(--text-dark);
}

.btn-muula-secondary:hover {
    border-color: var(--primary-green);
    background: #F0FAF4;
}

/* Portfolio Preview */
.portfolio-preview-muula {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
}

.preview-img-muula {
    width: 60px;
    height: 60px;
    border-radius: var(--radius-sm);
    object-fit: cover;
    background: var(--bg-light);
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 80px 24px;
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    max-width: 600px;
    margin: 0 auto;
}

.empty-state i {
    font-size: 4rem;
    color: var(--text-gray);
    margin-bottom: 20px;
}

.empty-state h3 {
    color: var(--text-dark);
    margin-bottom: 12px;
}

.empty-state p {
    color: var(--text-gray);
    margin-bottom: 24px;
}

/* Mobile Filter Drawer */
.filter-drawer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--bg-white);
    border-radius: 24px 24px 0 0;
    padding: 24px;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    z-index: 1000;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
}

.filter-drawer.active {
    transform: translateY(0);
}

.filter-drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    z-index: 999;
    display: none;
}

.filter-drawer-overlay.active {
    display: block;
}

.filter-drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border-light);
}

.filter-group {
    margin-bottom: 24px;
}

.filter-group label {
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 12px;
    display: block;
}

.floating-filter-btn {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--primary-green);
    color: white;
    border: none;
    box-shadow: var(--shadow-lg);
    cursor: pointer;
    z-index: 100;
    display: none;
    transition: all 0.3s ease;
}

.floating-filter-btn:hover {
    transform: scale(1.05);
}

/* Responsive */
@media (max-width: 768px) {
    .hero-title {
        font-size: 1.8rem;
    }
    
    .hero-subtitle {
        font-size: 0.95rem;
    }
    
    .painters-grid {
        grid-template-columns: 1fr;
        gap: 20px;
        padding: 0 16px 80px;
    }
    
    .filter-section {
        display: none;
    }
    
    .floating-filter-btn {
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .results-header {
        flex-direction: column;
        align-items: flex-start;
        padding: 0 16px;
    }
    
    .chip span {
        display: none;
    }
    
    .chip i {
        margin: 0;
    }
    
    .chip {
        padding: 10px 14px;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .painters-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
}

/* Animation */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.painter-card-muula {
    animation: fadeInUp 0.4s ease forwards;
    opacity: 0;
}
</style>

<!-- Hero Section -->
<div class="painters-hero">
    <div class="hero-container">
        <h1 class="hero-title">Find Your Perfect Painter</h1>
        <p class="hero-subtitle">Discover skilled painters across Algeria. Quality work, fair prices.</p>
        
        <!-- Search Bar -->
        <div class="search-bar-modern">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="Search by painter name, city, or specialty..." value="<%= query.search || '' %>">
        </div>
    </div>
</div>

<!-- Floating Filter Button (Mobile) -->
<button class="floating-filter-btn" onclick="toggleFilterDrawer()">
    <i class="fas fa-sliders-h"></i>
</button>

<!-- Filter Drawer (Mobile) -->
<div class="filter-drawer-overlay" id="filterDrawerOverlay" onclick="toggleFilterDrawer()"></div>
<div class="filter-drawer" id="filterDrawer">
    <div class="filter-drawer-header">
        <h6 class="mb-0">Filter Painters</h6>
        <button class="btn-close" onclick="toggleFilterDrawer()"></button>
    </div>
    <form id="mobileFilterForm" action="/painters" method="GET">
        <div class="filter-group">
            <label>Wilaya</label>
            <select class="form-select" name="wilaya">
                <option value="">All Wilayas</option>
                <% wilayas.forEach(wilaya => { %>
                <option value="<%= wilaya.name %>" <%= query.wilaya === wilaya.name ? 'selected' : '' %>>
                    <%= wilaya.name %>
                </option>
                <% }); %>
            </select>
        </div>
        <div class="filter-group">
            <label>Availability</label>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="availability" value="true" 
                       id="mobileAvailable" <%= query.availability === 'true' ? 'checked' : '' %>>
                <label class="form-check-label" for="mobileAvailable">Available Now</label>
            </div>
        </div>
        <div class="filter-group">
            <label>Min Experience</label>
            <select class="form-select" name="minExperience">
                <option value="">Any</option>
                <option value="1" <%= query.minExperience === '1' ? 'selected' : '' %>>1+ years</option>
                <option value="3" <%= query.minExperience === '3' ? 'selected' : '' %>>3+ years</option>
                <option value="5" <%= query.minExperience === '5' ? 'selected' : '' %>>5+ years</option>
                <option value="10" <%= query.minExperience === '10' ? 'selected' : '' %>>10+ years</option>
            </select>
        </div>
        <div class="filter-group">
            <label>Min Rating</label>
            <select class="form-select" name="minRating">
                <option value="">Any</option>
                <option value="4" <%= query.minRating === '4' ? 'selected' : '' %>>4★ & above</option>
                <option value="3" <%= query.minRating === '3' ? 'selected' : '' %>>3★ & above</option>
            </select>
        </div>
        <div class="filter-group">
            <label>Price per m²</label>
            <div class="row g-2">
                <div class="col-6">
                    <input type="number" class="form-control" placeholder="Min" name="minPrice" value="<%= query.minPrice || '' %>">
                </div>
                <div class="col-6">
                    <input type="number" class="form-control" placeholder="Max" name="maxPrice" value="<%= query.maxPrice || '' %>">
                </div>
            </div>
        </div>
        <div class="d-grid gap-2">
            <button type="submit" class="btn" style="background: var(--primary-green); color: white; padding: 12px; border-radius: 40px; border: none; font-weight: 600;">Apply Filters</button>
            <a href="/painters" class="btn" style="background: transparent; border: 1px solid var(--border-light); padding: 12px; border-radius: 40px; text-align: center; text-decoration: none; color: var(--text-dark);">Reset All</a>
        </div>
        <% if (Object.keys(query).length > 0 && query.wilaya) { %>
        <input type="hidden" name="search" value="<%= query.search || '' %>">
        <% } %>
    </form>
</div>

<!-- Filter Chips (Desktop) -->
<div class="filter-section">
    <div class="filter-chips-modern">
        <div class="chip <%= !query.wilaya && !query.availability && !query.minRating ? 'active' : '' %>" data-filter="all">
            <i class="fas fa-th-large"></i><span>All Painters</span>
        </div>
        <div class="chip" data-filter="available" data-availability="true">
            <i class="fas fa-check-circle"></i><span>Available Now</span>
        </div>
        <div class="chip" data-filter="top-rated" data-rating="4">
            <i class="fas fa-star"></i><span>Top Rated</span>
        </div>
        <div class="chip" data-filter="experienced" data-experience="5">
            <i class="fas fa-trophy"></i><span>5+ Years Exp</span>
        </div>
        <% if (query.wilaya) { %>
        <div class="chip active">
            <i class="fas fa-map-marker-alt"></i><span><%= query.wilaya %></span>
        </div>
        <% } %>
    </div>
    
    <form id="desktopFilterForm" action="/painters" method="GET" style="display: none;">
        <input type="hidden" name="wilaya" id="desktopWilaya" value="<%= query.wilaya || '' %>">
        <input type="hidden" name="availability" id="desktopAvailability" value="<%= query.availability || '' %>">
        <input type="hidden" name="minExperience" id="desktopExperience" value="<%= query.minExperience || '' %>">
        <input type="hidden" name="minRating" id="desktopRating" value="<%= query.minRating || '' %>">
        <input type="hidden" name="search" id="desktopSearch" value="<%= query.search || '' %>">
    </form>
</div>

<!-- Results Header -->
<div class="results-header">
    <div class="results-count">
        <h3><%= painters.length %> painter<%= painters.length !== 1 ? 's' : '' %> found</h3>
        <p>Professional painters ready to bring your vision to life</p>
    </div>
    <div class="sort-modern">
        <select id="sortSelect">
            <option value="rating" <%= query.sort === 'rating' ? 'selected' : '' %>>Highest Rated</option>
            <option value="experience" <%= query.sort === 'experience' ? 'selected' : '' %>>Most Experienced</option>
            <option value="price_low" <%= query.sort === 'price_low' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="price_high" <%= query.sort === 'price_high' ? 'selected' : '' %>>Price: High to Low</option>
        </select>
    </div>
</div>

<!-- Painters Grid -->
<% if (painters.length === 0) { %>
<div class="painters-grid">
    <div class="empty-state">
        <i class="fas fa-search"></i>
        <h3>No painters found</h3>
        <p>Try adjusting your filters or search in a different area</p>
        <a href="/painters" class="btn-muula btn-muula-primary" style="display: inline-block; padding: 12px 28px;">Clear All Filters</a>
    </div>
</div>
<% } else { %>
<div class="painters-grid">
    <% painters.forEach((painter, cardIndex) => { 
        const portfolioImages = [];
        (painter.portfolio || []).forEach(project => {
            if (project.images && project.images.length > 0 && project.images[0].url) {
                portfolioImages.push(project.images[0].url);
            }
        });
        const coverImage = portfolioImages[0] || null;
    %>
    <div class="painter-card-muula" style="animation-delay: <%= cardIndex * 0.05 %>s" onclick="viewProfile('<%= painter._id %>')">
        <!-- Card Cover -->
        <div class="card-cover-muula">
            <% if (coverImage) { %>
                <img src="<%= coverImage %>" alt="Cover" onerror="this.style.display='none'">
            <% } %>
        </div>
        
        <!-- Avatar -->
        <div class="avatar-muula">
            <% if (painter.profilePicture && painter.profilePicture.url) { %>
                <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>" onerror="this.src='https://placehold.co/200x200/2C5F8A/white?text=P'">
            <% } else { %>
                <img src="https://placehold.co/200x200/2C5F8A/white?text=P" alt="<%= painter.name %>">
            <% } %>
            <% if (painter.verification?.status === 'verified') { %>
                <div class="verified-badge-muula">
                    <i class="fas fa-check"></i>
                </div>
            <% } %>
        </div>
        
        <!-- Card Body -->
        <div class="card-body-muula">
            <div class="painter-name-muula">
                <%= painter.name %>
            </div>
            <div class="location-muula">
                <i class="fas fa-map-marker-alt"></i>
                <%= painter.location?.wilaya || 'Algeria' %>
            </div>
            
            <!-- Stats Row -->
            <div class="stats-row-muula">
                <div class="stat-item-muula">
                    <span class="stat-value-muula"><%= painter.completedJobs || 0 %></span>
                    <span class="stat-label-muula">Jobs Done</span>
                </div>
                <div class="stat-item-muula">
                    <span class="stat-value-muula"><%= painter.experience || 0 %></span>
                    <span class="stat-label-muula">Years Exp</span>
                </div>
            </div>
            
            <!-- Rating -->
            <div class="rating-muula">
                <div class="stars-muula">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star <%= i <= Math.round(painter.rating || 0) ? 'text-warning' : 'text-muted' %>" style="color: <%= i <= Math.round(painter.rating || 0) ? '#FBBF24' : '#E2E8F0' %>;"></i>
                    <% } %>
                </div>
                <span class="rating-number-muula">(<%= (painter.rating || 0).toFixed(1) %>)</span>
            </div>
            
            <!-- Specialties -->
            <% const specialties = painter.specialization || []; %>
            <% if (specialties.length > 0) { %>
            <div class="specialties-muula">
                <% specialties.slice(0, 2).forEach(spec => { %>
                    <span class="specialty-tag-muula"><%= spec %></span>
                <% }) %>
                <% if (specialties.length > 2) { %>
                    <span class="specialty-tag-muula">+<%= specialties.length - 2 %></span>
                <% } %>
            </div>
            <% } %>
            
            <!-- Portfolio Preview -->
            <% if (portfolioImages.length > 0) { %>
            <div class="portfolio-preview-muula">
                <% portfolioImages.slice(0, 3).forEach((img, idx) => { %>
                    <img src="<%= img %>" class="preview-img-muula" alt="Work" onerror="this.style.display='none'">
                <% }) %>
            </div>
            <% } %>
            
            <!-- Price & Availability -->
            <div class="price-section-muula">
                <div class="price-muula">
                    <%= painter.pricePerSqm || 0 %><small> DA/m²</small>
                </div>
                <div class="availability-muula <%= painter.availability === 'available' ? 'available' : 'busy' %>">
                    <%= painter.availability === 'available' ? 'Available' : 'Busy' %>
                </div>
            </div>
            
            <!-- Actions -->
            <div class="actions-muula" onclick="event.stopPropagation()">
                <a href="/painters/<%= painter._id %>" class="btn-muula btn-muula-secondary">Profile</a>
                <a href="/painters/<%= painter._id %>/order" class="btn-muula btn-muula-primary">Hire</a>
            </div>
        </div>
    </div>
    <% }); %>
</div>
<% } %>

<script>
// View profile function
function viewProfile(painterId) {
    window.location.href = `/painters/${painterId}`;
}

// Toggle filter drawer (mobile)
function toggleFilterDrawer() {
    const drawer = document.getElementById('filterDrawer');
    const overlay = document.getElementById('filterDrawerOverlay');
    drawer.classList.toggle('active');
    overlay.classList.toggle('active');
}

// Search functionality
document.getElementById('searchInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
        const url = new URL(window.location);
        url.searchParams.set('search', this.value);
        window.location.href = url.toString();
    }
});

// Sort functionality
document.getElementById('sortSelect').addEventListener('change', function() {
    const url = new URL(window.location);
    url.searchParams.set('sort', this.value);
    window.location.href = url.toString();
});

// Filter chips (desktop)
document.querySelectorAll('.chip[data-filter]').forEach(chip => {
    chip.addEventListener('click', function() {
        const filter = this.dataset.filter;
        const url = new URL(window.location);
        
        if (filter === 'all') {
            window.location.href = '/painters';
        } else if (filter === 'available') {
            url.searchParams.set('availability', 'true');
            window.location.href = url.toString();
        } else if (filter === 'top-rated') {
            url.searchParams.set('minRating', '4');
            window.location.href = url.toString();
        } else if (filter === 'experienced') {
            url.searchParams.set('minExperience', '5');
            window.location.href = url.toString();
        }
    });
});

// Close filter drawer on escape
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const drawer = document.getElementById('filterDrawer');
        if (drawer.classList.contains('active')) {
            toggleFilterDrawer();
        }
    }
});
</script>

<%- include('../partials/footer') %>
