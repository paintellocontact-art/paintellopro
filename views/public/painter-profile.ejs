<%- include('../partials/header', { title: title }) %>

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
.swiper {
  width: 100%;
  height: 500px;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 12px 40px rgba(0,0,0,0.15);
}
.swiper-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.swiper-button-next, .swiper-button-prev {
  color: white;
  background: rgba(0,0,0,0.6);
  width: 50px;
  height: 50px;
  border-radius: 50%;
  backdrop-filter: blur(10px);
  border: 2px solid rgba(255,255,255,0.3);
}
.swiper-button-next:hover, .swiper-button-prev:hover {
  background: #007bff;
}
.swiper-pagination-bullet-active {
  background: #007bff;
}
.thumbnail-swiper {
  height: 100px;
  margin-top: 20px;
}
.thumbnail-swiper .swiper-slide {
  opacity: 0.5;
  transition: all 0.3s ease;
  cursor: pointer;
}
.thumbnail-swiper .swiper-slide-thumb-active {
  opacity: 1;
  border: 2px solid #007bff;
}
.lightbox {
  display: none;
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.95);
  backdrop-filter: blur(10px);
  justify-content: center;
  align-items: center;
  flex-direction: column;
}
.lightbox img {
  max-width: 90%;
  max-height: 85vh;
  border-radius: 10px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.6);
}
.lightbox-close {
  position: absolute;
  top: 25px;
  right: 35px;
  color: white;
  font-size: 2rem;
  cursor: pointer;
  background: rgba(0,0,0,0.6);
  padding: 8px 15px;
  border-radius: 50%;
}
.project-count {
  background: #007bff;
  color: white;
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  margin-left: 10px;
}
</style>

<div class="container py-4">
  <!-- Painter Header -->
  <div class="row mb-5">
    <div class="col-md-4 text-center">
      <div class="avatar-large mb-3 mx-auto" style="width: 150px; height: 150px; border-radius: 50%; overflow: hidden;">
        <% if (painter.profilePicture && painter.profilePicture.url) { %>
          <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>"
            style="width:100%;height:100%;object-fit:cover;"
            onerror="this.src='https://via.placeholder.com/150/007bff/ffffff?text=P'">
        <% } else { %>
          <div class="d-flex align-items-center justify-content-center h-100 bg-primary text-white">
            <i class="fas fa-paint-roller fa-2x"></i>
          </div>
        <% } %>
      </div>

      <% if (painter.verification && painter.verification.status === 'verified') { %>
      <div class="mb-3">
        <span class="badge bg-success fs-6">
          <i class="fas fa-check-circle me-1"></i>Verified Pro Painter
        </span>
      </div>
      <% } %>

      <h4 class="text-primary mb-1"><%= painter.pricePerSqm %> DZD</h4>
      <small class="text-muted">Price per m²</small>
      <a href="/painters/<%= painter._id %>/order" class="btn btn-primary btn-lg w-100 mt-3">
        <i class="fas fa-paint-brush me-2"></i>Hire This Painter
      </a>
    </div>

    <div class="col-md-8">
      <h1 class="h3 mb-1"><%= painter.name %></h1>
      <p class="text-muted mb-3">
        <i class="fas fa-map-marker-alt me-1"></i>
        <%= painter.location?.wilaya || 'Algeria' %>
      </p>

      <div class="d-flex align-items-center mb-2">
        <% for (let i = 1; i <= 5; i++) { %>
          <i class="fas fa-star <%= i <= (painter.rating || 0) ? 'text-warning' : 'text-muted' %> fs-5"></i>
        <% } %>
        <span class="fw-bold ms-2"><%= (painter.rating || 0).toFixed(1) %></span>
        <span class="text-muted ms-1">(<%= painter.completedJobs || 0 %> jobs)</span>
      </div>

      <% if (painter.availability === 'available') { %>
        <span class="badge bg-success p-2"><i class="fas fa-check-circle me-1"></i>Available</span>
      <% } else if (painter.availability === 'busy') { %>
        <span class="badge bg-warning p-2"><i class="fas fa-clock me-1"></i>Busy</span>
      <% } else { %>
        <span class="badge bg-secondary p-2"><i class="fas fa-times-circle me-1"></i>Unavailable</span>
      <% } %>
    </div>
  </div>

  <!-- Portfolio Section -->
  <% 
    const portfolio = painter.portfolio || [];
    const allImages = [];
    portfolio.forEach((p) => {
      if (Array.isArray(p.images)) {
        p.images.forEach(i => i.url && allImages.push(i.url));
      } else if (p.flickrUrl) {
        allImages.push(p.flickrUrl);
      }
    });
  %>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-light border-0">
      <h4 class="mb-0 d-flex align-items-center">
        <i class="fas fa-images me-2"></i>Portfolio Gallery
        <% if (allImages.length > 0) { %>
        <span class="project-count"><%= allImages.length %> Images</span>
        <% } %>
      </h4>
    </div>
    <div class="card-body">
      <% if (allImages.length === 0) { %>
        <div class="text-center py-5">
          <i class="fas fa-images fa-3x text-muted mb-3"></i>
          <h5 class="text-muted">No portfolio images yet</h5>
        </div>
      <% } else { %>
        <!-- Main Swiper -->
        <div class="swiper portfolio-swiper">
          <div class="swiper-wrapper">
            <% allImages.forEach((url, i) => { %>
              <div class="swiper-slide">
                <img src="<%= url %>" alt="Project <%= i + 1 %>" onclick="openLightbox(<%= i %>)">
              </div>
            <% }) %>
          </div>
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
          <div class="swiper-pagination"></div>
        </div>

        <!-- Thumbnail Swiper -->
        <div class="swiper thumbnail-swiper mt-3">
          <div class="swiper-wrapper">
            <% allImages.forEach((url) => { %>
              <div class="swiper-slide">
                <img src="<%= url %>" alt="Thumbnail" />
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox">
    <span class="lightbox-close" onclick="closeLightbox()">&times;</span>
    <img id="lightbox-img" src="">
  </div>
</div>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
const allImages = <%= JSON.stringify(allImages) %>;
let currentLightboxIndex = 0;

document.addEventListener('DOMContentLoaded', () => {
  if (allImages.length === 0) return;

  const thumbs = new Swiper('.thumbnail-swiper', {
    spaceBetween: 10,
    slidesPerView: 'auto',
    freeMode: true,
    watchSlidesProgress: true,
  });

  const swiper = new Swiper('.portfolio-swiper', {
    loop: allImages.length > 1,
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
    thumbs: { swiper: thumbs },
  });
});

function openLightbox(index) {
  const lightbox = document.getElementById('lightbox');
  const img = document.getElementById('lightbox-img');
  currentLightboxIndex = index;
  img.src = allImages[index];
  lightbox.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeLightbox() {
  document.getElementById('lightbox').style.display = 'none';
  document.body.style.overflow = 'auto';
}

document.addEventListener('keydown', e => {
  const lb = document.getElementById('lightbox');
  if (lb.style.display === 'flex') {
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') changeImage(1);
    if (e.key === 'ArrowLeft') changeImage(-1);
  }
});

function changeImage(dir) {
  currentLightboxIndex += dir;
  if (currentLightboxIndex < 0) currentLightboxIndex = allImages.length - 1;
  if (currentLightboxIndex >= allImages.length) currentLightboxIndex = 0;
  document.getElementById('lightbox-img').src = allImages[currentLightboxIndex];
}
</script>

<%- include('../partials/footer') %>


