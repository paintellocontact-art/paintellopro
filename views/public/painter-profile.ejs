<%- include('../partials/header', { title: 'Portfolio - Paintello Pro' }) %>

<style>
.carousel {
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
}
.carousel-inner { height: 500px; }
.carousel-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  cursor: pointer;
  transition: transform 0.3s ease;
}
.carousel-item img:hover { transform: scale(1.02); }
.carousel-control-prev, .carousel-control-next {
  width: 60px; height: 60px;
  background: rgba(0,0,0,0.6);
  border-radius: 50%;
  top: 50%;
  transform: translateY(-50%);
  border: none;
}
.carousel-control-prev:hover, .carousel-control-next:hover {
  background: #007bff;
}
.thumbnail-container {
  display: flex;
  gap: 10px;
  margin-top: 20px;
  overflow-x: auto;
  padding: 10px;
}
.thumbnail-item {
  flex: 0 0 auto;
  width: 100px;
  height: 80px;
  border-radius: 10px;
  overflow: hidden;
  opacity: 0.7;
  cursor: pointer;
  transition: 0.3s;
}
.thumbnail-item.active, .thumbnail-item:hover {
  opacity: 1;
  border: 3px solid #007bff;
}
.thumbnail-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
/* Lightbox */
.lightbox {
  display: none;
  position: fixed;
  z-index: 9999;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.95);
  justify-content: center;
  align-items: center;
}
.lightbox img {
  max-width: 90%;
  max-height: 90vh;
  border-radius: 10px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.7);
}
.lightbox-close {
  position: absolute;
  top: 20px; right: 30px;
  font-size: 2rem;
  color: white;
  cursor: pointer;
}
@media (max-width: 768px) {
  .carousel-inner { height: 350px; }
  .thumbnail-item { width: 80px; height: 60px; }
}
</style>

<div class="container py-5">
  <div class="row mb-5">
    <div class="col-md-4 text-center">
      <div class="avatar-large mb-3 mx-auto" style="width:150px;height:150px;border-radius:50%;overflow:hidden;">
        <% if (painter.profilePicture && painter.profilePicture.url) { %>
          <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>" style="width:100%;height:100%;object-fit:cover;">
        <% } else { %>
          <div class="d-flex align-items-center justify-content-center bg-primary w-100 h-100 text-white">
            <i class="fas fa-user fa-3x"></i>
          </div>
        <% } %>
      </div>
      <h4 class="fw-bold mb-1"><%= painter.name %></h4>
      <p class="text-muted mb-1"><i class="fas fa-map-marker-alt me-1"></i><%= painter.location.wilaya %>, Algeria</p>
      <p class="fw-semibold text-primary"><%= painter.pricePerSqm %> DZD/m²</p>
      <a href="/painters/<%= painter._id %>/order" class="btn btn-primary w-100">
        <i class="fas fa-paint-roller me-2"></i>Hire This Painter
      </a>
    </div>

    <div class="col-md-8">
      <h2 class="mb-4"><i class="fas fa-images me-2"></i>Portfolio Gallery</h2>

      <% 
      const portfolio = painter.portfolio || [];
      const allImages = [];

      portfolio.forEach((p) => {
        if (p.images && p.images.length > 0) {
          p.images.forEach(img => allImages.push(img.url));
        } else if (p.flickrUrl) {
          allImages.push(p.flickrUrl);
        }
      });
      %>

      <% if (allImages.length === 0) { %>
        <div class="text-center py-5">
          <i class="fas fa-images fa-3x text-muted mb-3"></i>
          <h5 class="text-muted">No portfolio photos yet</h5>
        </div>
      <% } else { %>
        <!-- Carousel -->
        <div id="portfolioCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <% allImages.forEach((img, i) => { %>
              <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                <img src="<%= img %>" alt="Project Image <%= i+1 %>" onclick="openLightbox(<%= i %>)" onerror="this.src='https://via.placeholder.com/800x500?text=Image+Not+Found'">
              </div>
            <% }) %>
          </div>

          <button class="carousel-control-prev" type="button" data-bs-target="#portfolioCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#portfolioCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>
        </div>

        <!-- Thumbnails -->
        <div class="thumbnail-container mt-3">
          <% allImages.forEach((img, i) => { %>
            <div class="thumbnail-item <%= i === 0 ? 'active' : '' %>" onclick="goToSlide(<%= i %>)">
              <img src="<%= img %>" alt="Thumbnail <%= i+1 %>">
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Lightbox -->
<div id="lightbox" class="lightbox" onclick="closeLightbox()">
  <span class="lightbox-close" onclick="closeLightbox()">&times;</span>
  <img id="lightbox-img" src="">
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
const allImages = <%= JSON.stringify(allImages) %>;
const carousel = new bootstrap.Carousel(document.getElementById('portfolioCarousel'));
let lightbox = document.getElementById('lightbox');
let lightboxImg = document.getElementById('lightbox-img');

function goToSlide(i) {
  carousel.to(i);
  document.querySelectorAll('.thumbnail-item').forEach((el, idx) => {
    el.classList.toggle('active', idx === i);
  });
}

function openLightbox(i) {
  lightbox.style.display = 'flex';
  lightboxImg.src = allImages[i];
  document.body.style.overflow = 'hidden';
}

function closeLightbox() {
  lightbox.style.display = 'none';
  document.body.style.overflow = 'auto';
}
</script>

<%- include('../partials/footer') %>

