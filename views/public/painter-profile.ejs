<%- include('../partials/header', { title: 'My Portfolio', painter: painter }) %>

<div class="container py-5">
  <!-- Painter Info Section -->
  <div class="text-center mb-5">
    <h2 class="fw-bold text-primary"><%= painter.name %></h2>
    <p class="text-muted mb-2">
      <i class="fas fa-map-marker-alt me-2"></i>
      <%= painter.location?.wilaya || 'Unknown Wilaya' %>, Algeria
    </p>

    <% if (painter.verification && painter.verification.status === 'verified') { %>
      <span class="badge bg-success mb-3"><i class="fas fa-check-circle me-1"></i>Verified</span>
    <% } %>

    <div>
      <% for (let i = 1; i <= 5; i++) { %>
        <i class="fas fa-star <%= i <= (painter.rating || 0) ? 'text-warning' : 'text-muted' %>"></i>
      <% } %>
      <span class="fw-bold ms-2"><%= (painter.rating || 0).toFixed(1) %></span>
      <span class="text-muted">(<%= painter.completedJobs || 0 %> jobs)</span>
    </div>
  </div>

  <!-- Portfolio Section -->
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-light">
      <h4 class="mb-0"><i class="fas fa-images me-2"></i>Portfolio Gallery</h4>
    </div>
    <div class="card-body">

      <% if (!painter.portfolio || painter.portfolio.length === 0) { %>
        <div class="text-center text-muted py-5">
          <i class="fas fa-images fa-3x mb-3"></i>
          <h5>No projects yet</h5>
          <p>Send your photos via WhatsApp to be added to your portfolio.</p>
        </div>
      <% } else { %>
        <% painter.portfolio.forEach((project, index) => { %>
          <div class="card mb-5 border-0 shadow-sm card-hover">
            <div class="card-body">
              <h5 class="text-primary mb-1"><%= project.title || 'Untitled Project' %></h5>
              <p class="text-muted small mb-2">
                <%= project.description || 'No description provided' %>
              </p>
              <div class="mb-2">
                <span class="badge bg-info text-dark me-1"><%= project.category || 'General' %></span>
                <% if (project.clientType) { %>
                  <span class="badge bg-secondary me-1"><%= project.clientType %></span>
                <% } %>
                <% if (project.projectSize) { %>
                  <span class="badge bg-warning text-dark"><%= project.projectSize %></span>
                <% } %>
              </div>
            </div>

            <% if (project.images && project.images.length > 0) { %>
              <div id="carousel<%= index %>" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                  <% project.images.forEach((img, i) => { %>
                    <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                      <img src="<%= img.url %>" class="d-block w-100"
                           alt="Project Image"
                           style="height: 400px; object-fit: cover; border-radius: 10px;">
                    </div>
                  <% }) %>
                </div>
                <% if (project.images.length > 1) { %>
                  <button class="carousel-control-prev" type="button" data-bs-target="#carousel<%= index %>" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                  </button>
                  <button class="carousel-control-next" type="button" data-bs-target="#carousel<%= index %>" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                  </button>
                <% } %>
              </div>
            <% } else { %>
              <div class="text-center py-4 text-muted">
                <img src="https://via.placeholder.com/600x400?text=No+Images" 
                     class="img-fluid rounded" alt="No Images">
              </div>
            <% } %>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<style>
.card-hover {
  transition: transform 0.2s ease, box-shadow 0.3s ease;
}
.card-hover:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}
.carousel-inner img {
  transition: transform 0.3s ease;
}
.carousel-inner img:hover {
  transform: scale(1.03);
}
</style>

<%- include('../partials/footer') %>



