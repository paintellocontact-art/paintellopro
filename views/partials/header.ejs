<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<%
  const pixelId = typeof fbPixelId !== 'undefined' && fbPixelId ? fbPixelId : (process.env.FB_PIXEL_ID || '');
  const pageViewEventId = typeof metaEventIdPageView !== 'undefined' && metaEventIdPageView ? metaEventIdPageView : 'pv_' + Date.now() + '_' + Math.random().toString(36).slice(2);
%>
<% if (pixelId) { %>
<!-- Facebook Pixel - EXACT SAME AS PAINTELLO HOME THAT WORKS -->
<script>
!function(f,b,e,v,n,t,s)
{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window, document,'script',
'https://connect.facebook.net/en_US/fbevents.js');

fbq('init', '<%= process.env.FB_PIXEL_ID %>');

// ✅ SAME AS HOME - ALWAYS TRACK WITH EVENTID
fbq('track', 'PageView', {}, {
  eventID: '<%= typeof metaEventIdPageView !== "undefined" && metaEventIdPageView ? metaEventIdPageView : "" %>'
});

console.log('✅ Pixel PageView fired:', '<%= typeof metaEventIdPageView !== "undefined" ? metaEventIdPageView : "" %>');
</script>
<noscript>
  <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= process.env.FB_PIXEL_ID %>&ev=PageView&noscript=1"/>
</noscript>
<% } %>

    <title><%= title %> - Paintello Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <style>
        :root { --primary-blue:#295797; --accent-blue:#1C84C1; --text-dark:#2D3748; --bg-light:#E8EEF6; --bg-white:#FFFFFF; --border-light:#D1DCE6; }
        body { font-family: 'Inter', sans-serif; background: var(--bg-light); }
        .navbar-modern { background: var(--bg-white)!important; box-shadow: 0 2px 8px rgba(0,0,0,0.08); padding:12px 0; }
        .navbar-brand-modern { font-weight:800; font-size:1.5rem; color: var(--primary-blue); display:flex; gap:8px; align-items:center; text-decoration:none; }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-modern sticky-top">
    <div class="container">
        <a class="navbar-brand navbar-brand-modern" href="/ar"><i class="fas fa-paint-roller"></i><span>Paintello Pro</span></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"><span class="navbar-toggler-icon"></span></button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="/ar">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/painters">Find Painters</a></li>
            </ul>
        </div>
    </div>
</nav>
