    <title><%= title %> - Paintello Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <style>
        :root { --primary-blue:#295797; --accent-blue:#1C84C1; --primary-dark:#1E3F5C; --text-dark:#2D3748; --bg-light:#E8EEF6; --bg-white:#FFFFFF; --border-light:#D1DCE6; }
        body { font-family: 'Inter', sans-serif; color: var(--text-dark); background: var(--bg-light); }
        .navbar-modern { background: var(--bg-white) !important; box-shadow: 0 2px 8px rgba(41,87,151,0.08); padding: 12px 0; }
        .navbar-brand-modern { font-weight:800; font-size:1.5rem; background:linear-gradient(135deg,var(--primary-blue),var(--accent-blue)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; display:flex; align-items:center; gap:8px; }
        .nav-link-modern { color:var(--text-dark)!important; font-weight:500; padding:8px 16px!important; }
        .btn-login-modern { background:transparent; border:1px solid var(--border-light); padding:8px 20px; border-radius:40px; text-decoration:none; }
        .btn-signup-modern { background:var(--primary-blue); color:white; padding:8px 20px; border-radius:40px; text-decoration:none; }
        .avatar-dropdown { display:flex; align-items:center; gap:10px; padding:6px 12px; border-radius:40px; background:var(--bg-light); }
        .avatar-small { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,var(--primary-blue),var(--accent-blue)); display:flex; align-items:center; justify-content:center; color:white; }
    </style>
</head>
<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WQVTHK89" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<nav class="navbar navbar-expand-lg navbar-modern sticky-top">
    <div class="container">
        <a class="navbar-brand navbar-brand-modern" href="/ar"><i class="fas fa-paint-roller"></i><span>Paintello Pro</span></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"><span class="navbar-toggler-icon"></span></button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link nav-link-modern" href="/ar"><i class="fas fa-home me-1"></i> Home</a></li>
                <li class="nav-item"><a class="nav-link nav-link-modern" href="/painters"><i class="fas fa-search me-1"></i> Find Painters</a></li>
                <% if (typeof sessionPainter !== 'undefined' && sessionPainter) { %>
                <li class="nav-item"><a class="nav-link nav-link-modern" href="/painter/dashboard"><i class="fas fa-chart-line me-1"></i> Dashboard</a></li>
                <% } %>
            </ul>
            <ul class="navbar-nav">
                <% if (typeof sessionPainter !== 'undefined' && sessionPainter) { %>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <div class="avatar-dropdown">
                                <div class="avatar-small">
                                    <% if (sessionPainter.profilePicture && sessionPainter.profilePicture.url) { %>
                                        <img src="<%= sessionPainter.profilePicture.url %>" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">
                                    <% } else { %>
                                        <i class="fas fa-brush"></i>
                                    <% } %>
                                </div>
                                <span><%= sessionPainter.name %></span>
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/painter/dashboard">Dashboard</a></li>
                            <li><a class="dropdown-item" href="/painter/profile">My Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/index/logout">Logout</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <li class="nav-item me-2"><a class="btn-login-modern" href="/auth/login-painter">Login</a></li>
                    <li class="nav-item"><a class="btn-signup-modern" href="/auth/register-painter">Sign Up</a></li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>
