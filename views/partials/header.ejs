<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<%
  const pixelId = typeof fbPixelId !== 'undefined' && fbPixelId ? fbPixelId : (typeof process !== 'undefined' && process.env && process.env.FB_PIXEL_ID ? process.env.FB_PIXEL_ID : '');
  const pageViewEventId = typeof metaEventIdPageView !== 'undefined' && metaEventIdPageView ? metaEventIdPageView : '';
  const advancedMatching = { country: 'dz' };
  if (typeof user !== 'undefined' && user) {
    if (user.email) advancedMatching.em = user.email;
    if (user.phone || user.numero) advancedMatching.ph = user.phone || user.numero;
    if (user.firstName) advancedMatching.fn = user.firstName;
    if (user.lastName) advancedMatching.ln = user.lastName;
  }
  if (typeof sessionPainter !== 'undefined' && sessionPainter) {
    if (!advancedMatching.em && sessionPainter.email) advancedMatching.em = sessionPainter.email;
    if (!advancedMatching.ph && sessionPainter.phone) advancedMatching.ph = sessionPainter.phone;
    if (!advancedMatching.fn && sessionPainter.firstName) advancedMatching.fn = sessionPainter.firstName;
    else if (!advancedMatching.fn && sessionPainter.name) advancedMatching.fn = sessionPainter.name;
    if (!advancedMatching.ln && sessionPainter.lastName) advancedMatching.ln = sessionPainter.lastName;
  }
%>
<% if (pixelId) { %>
<!-- Facebook Pixel Code - MATCH HOME -->
<script>
!function(f,b,e,v,n,t,s)
{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window, document,'script',
'https://connect.facebook.net/en_US/fbevents.js');

fbq('init', <%- JSON.stringify(pixelId) %>, <%- JSON.stringify(advancedMatching).replace(/</g, '\\u003c') %>);

// ✅ ALWAYS track PageView - SAME AS HOME REFERENCE
fbq('track', 'PageView', {}, {
  eventID: <%- JSON.stringify(pageViewEventId || ('pv_' + Date.now())) %>
});

console.log('🎯 Pixel ID:', <%- JSON.stringify(pixelId) %>);
console.log('🎯 PageView Event ID:', <%- JSON.stringify(pageViewEventId) %>);
</script>
<noscript>
  <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= pixelId %>&ev=PageView&noscript=1" />
</noscript>
<% } else { %>
<script>console.warn('⚠️ FB_PIXEL_ID missing - pixel not loaded');</script>
<% } %>

    <!-- Google Tag Manager -->
