<% if (typeof isAndroidApp !== 'undefined' && isAndroidApp) { %>
    <!-- Bottom Navigation (for Android app) -->
    <div class="bottom-nav" id="bottomNav">
        <a href="/painter/dashboard" class="nav-item active">
            <i class="fas fa-home"></i>
            <span>الرئيسية</span>
        </a>
        <a href="/painter/store" class="nav-item">
            <i class="fas fa-store"></i>
            <span>المتجر</span>
        </a>
        <a href="/painter/orders" class="nav-item">
            <i class="fas fa-clipboard-list"></i>
            <span>الطلبات</span>
            <span class="badge" id="orderBadge" style="display:none;">3</span>
        </a>
        <a href="/painter/profile" class="nav-item">
            <i class="fas fa-user"></i>
            <span>حسابي</span>
        </a>
    </div>

    <script>
      // Highlight active tab
      (function() {
        const links = document.querySelectorAll('.bottom-nav .nav-item');
        const currentPath = window.location.pathname;
        links.forEach(link => {
          link.classList.remove('active');
          if (link.getAttribute('href') === currentPath ||
              currentPath.startsWith('/painter/dashboard') && link.getAttribute('href') === '/painter/dashboard' ||
              currentPath.startsWith('/painter/store') && link.getAttribute('href') === '/painter/store' ||
              currentPath.startsWith('/painter/orders') && link.getAttribute('href') === '/painter/orders' ||
              currentPath.startsWith('/painter/profile') && link.getAttribute('href') === '/painter/profile') {
            link.classList.add('active');
          }
        });
      })();
    </script>

    </div><!-- close app-content -->
    </div><!-- close app-shell -->
<% } %>
