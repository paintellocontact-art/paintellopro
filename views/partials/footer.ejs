<!-- ========================================== -->
<!-- DETECTION & BEHAVIOUR SCRIPT               -->
<!-- ========================================== -->
<script>
(function(){
    // Detect Android app (via user-agent or injected JS interface)
    const isApp = navigator.userAgent.includes('PaintelloProApp') || (typeof window.Android !== 'undefined' && window.Android && window.Android.isApp && window.Android.isApp());
    
    const bottomNav = document.getElementById('appBottomNav');
    
    if (isApp && bottomNav) {
        // Show the native bottom bar
        bottomNav.style.display = 'flex';
        document.body.classList.add('is-android-app');
        
        // Highlight active nav item based on current path
        const currentPath = window.location.pathname;
        const navItems = bottomNav.querySelectorAll('.nav-item');
        navItems.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === currentPath || (currentPath.startsWith('/painters') && link.getAttribute('href') === '/painters')) {
                link.classList.add('active');
            }
        });
    } else if (bottomNav) {
        // Ensure it's hidden on web
        bottomNav.style.display = 'none';
    }
})();
</script>
  
