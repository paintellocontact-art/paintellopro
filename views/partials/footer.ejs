<!-- 4. LOGIC ENGINE (JAVASCRIPT)               -->
<!-- ========================================== -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        
        // --- PRO ACTIVE ENVIRONMENT WEBVIEW DETECTOR ---
        // Checks user-agent hooks or standard system indicators
        const isAndroidWebView = navigator.userAgent.includes('PaintelloProApp') || (window.Android !== undefined);
        const bottomNavElement = document.getElementById('mobileBottomNav');

        if (isAndroidWebView) {
            // User is browsing inside your Android App WebView container
            document.body.classList.add('is-android-app');
            if(bottomNavElement) {
                bottomNavElement.classList.remove('d-none'); // Reveal structural app bar exclusively
            }
            
            // Set App Active State Links Dynamically
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('.mobile-bottom-nav .nav-item');
            navLinks.forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }
            });
        } else {
            // User is on mobile Chrome, Safari or Desktop Web -> Hide native app bar
            if(bottomNavElement) {
                bottomNavElement.style.setProperty('display', 'none', 'important');
            }
        }

        // --- PRESERVED ORIGINAL FUNCTIONAL ENGINE ---
        // Wilaya select number parsing
        const wilayaSelect = document.getElementById('wilaya');
        const wilayaNumberInput = document.getElementById('wilayaNumber');
        
        if (wilayaSelect && wilayaNumberInput) {
            wilayaSelect.addEventListener('change', function() {
                const selectedOption = this.options[this.selectedIndex];
                if (selectedOption.value) {
                    const match = selectedOption.text.match(/\((\d+)\)/);
                    if (match && match[1]) {
                        wilayaNumberInput.value = parseInt(match[1]);
                    } else {
                        wilayaNumberInput.value = '';
                    }
                } else {
                    wilayaNumberInput.value = '';
                }
            });
            if (wilayaSelect.value) {
                wilayaSelect.dispatchEvent(new Event('change'));
            }
        }

        // Phone Sanitizer Rule
        const phoneInput = document.getElementById('phone');
        if (phoneInput) {
            phoneInput.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '');
                if (this.value.length > 10) { this.value = this.value.slice(0, 10); }
            });
        }

        // Master Registration Form Validation
        const form = document.querySelector('form');
        if (form && form.action.includes('/auth/register-painter')) {
            form.addEventListener('submit', function(e) {
                let isValid = true;
                const errorMessages = [];

                const currentWilaya = document.getElementById('wilaya');
                if (currentWilaya && (!currentWilaya.value || currentWilaya.value === '')) {
                    isValid = false;
                    errorMessages.push('Please select a wilaya');
                }

                const password = document.getElementById('password');
                const confirmPassword = document.getElementById('confirmPassword');
                if (password && confirmPassword) {
                    if (password.value !== confirmPassword.value) {
                        isValid = false;
                        errorMessages.push('Passwords do not match');
                    }
                    if (password.value.length < 6) {
                        isValid = false;
                        errorMessages.push('Password must be at least 6 characters long');
                    }
                }

                const termsCheckbox = document.getElementById('terms');
                if (termsCheckbox && !termsCheckbox.checked) {
                    isValid = false;
                    errorMessages.push('Please accept the Terms of Service and Privacy Policy');
                }

                const idCardInput = document.getElementById('idCard');
                if (idCardInput && !idCardInput.files.length) {
                    isValid = false;
                    errorMessages.push('ID card photo is required');
                }

                if (!isValid) {
                    e.preventDefault();
                    alert('Please fix the following errors:\n\n• ' + errorMessages.join('\n• '));
                    return false;
                }

                const submitBtn = form.querySelector('button[type="submit"]');
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Processing...';
                }
            });
        }

        // Real-time validation visual indicators
        const elementsToValidate = document.querySelectorAll('input[required], select[required]');
        elementsToValidate.forEach(input => {
            input.addEventListener('blur', function() {
                if (!this.value) {
                    this.classList.add('is-invalid');
                    this.classList.remove('is-valid');
                } else {
                    this.classList.remove('is-invalid');
                    this.classList.add('is-valid');
                }
            });
        });
    });
</script>
