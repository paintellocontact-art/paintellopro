                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/painter/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a class="dropdown-item" href="/painter/profile"><i class="fas fa-user-circle"></i> My Profile</a></li>
