                    </li>
                <% } else { %>
                    <li class="nav-item me-2"><a class="btn-login-modern" href="/auth/login-painter"><i class="fas fa-sign-in-alt me-1"></i> Login</a></li>
                    <li class="nav-item"><a class="btn-signup-modern" href="/auth/register-painter"><i class="fas fa-user-plus me-1"></i> Sign Up</a></li>
