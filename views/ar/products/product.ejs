<%- include('../../partials/header', { 
  title: product.name + ' - Paintello Pro',

  metaEventIdView: typeof metaEventIdView !== 'undefined' ? metaEventIdView : '',
  metaEventIdCart: typeof metaEventIdCart !== 'undefined' ? metaEventIdCart : '',
  user: typeof user !== 'undefined' ? user : null,
  sessionPainter: typeof sessionPainter !== 'undefined' ? sessionPainter : null,
  whatsappPhone: typeof whatsappPhone !== 'undefined' ? whatsappPhone : '213796530868'
}) %>

<style>
  :root { --primary-blue:#295797; --accent-blue:#1C84C1; --primary-dark:#1E3F5C; --text-dark:#2D3748; --text-gray:#4A5568; --bg-light:#E8EEF6; --bg-white:#FFFFFF; --border-light:#D1DCE6; }
  body { font-family: 'Tajawal','Cairo',sans-serif; background-color: var(--bg-light); }
  .product-detail-section { padding:60px 0; }
  .image-gallery { display:flex; gap:15px; margin-bottom:15px; }
  .thumbnails-col { display:flex; flex-direction:column; gap:10px; max-height:500px; overflow-y:auto; }
  .thumb-item { width:70px; height:70px; border:2px solid transparent; border-radius:10px; overflow:hidden; cursor:pointer; background:none; }
  .thumb-item.active { border-color:var(--primary-blue); }
  .thumb-item img { width:100%; height:100%; object-fit:cover; }
  .main-image-wrapper { flex:1; position:relative; background:var(--bg-white); border-radius:24px; display:flex; align-items:center; justify-content:center; min-height:450px; overflow:hidden; }
  .main-image { max-width:100%; max-height:500px; object-fit:contain; padding:20px; }
  .gallery-arrow { position:absolute; top:50%; transform:translateY(-50%); background:rgba(0,0,0,0.3); color:white; border:none; width:40px; height:40px; border-radius:50%; cursor:pointer; display:none; }
  .main-image-wrapper:hover .gallery-arrow { display:flex; align-items:center; justify-content:center; }
  .left-arrow { left:10px; } .right-arrow { right:10px; }
  .product-info-card { background:var(--bg-white); border-radius:24px; padding:32px; border:1px solid var(--border-light); }
  .category-badge { display:inline-block; background:rgba(41,87,151,0.1); color:var(--primary-blue); padding:4px 14px; border-radius:40px; font-size:0.8rem; font-weight:600; margin-bottom:12px; }
  .product-title { font-size:2rem; font-weight:700; color:var(--text-dark); margin-bottom:16px; }
  .current-price { font-size:2.2rem; font-weight:800; color:var(--primary-blue); }
  .delivery-info { background:#f0f9ff; border-radius:16px; padding:16px; margin-bottom:24px; border:1px solid #d0e7ff; }
  .quantity-selector { display:flex; align-items:center; gap:12px; margin-bottom:20px; }
  .qty-controls { display:flex; align-items:center; border:1px solid var(--border-light); border-radius:40px; overflow:hidden; }
  .qty-btn { background:var(--bg-light); border:none; width:40px; height:40px; font-size:1.2rem; cursor:pointer; }
  .qty-input { width:50px; text-align:center; border:none; font-weight:600; }
  .btn-buy-now { width:100%; background:var(--primary-blue); color:white; border:none; padding:16px 24px; font-size:1.1rem; font-weight:700; border-radius:50px; margin-bottom:12px; display:flex; align-items:center; justify-content:center; }
  .btn-whatsapp-bulk { width:100%; background:#25D366; color:white; border:none; padding:14px 24px; font-weight:600; border-radius:50px; margin-bottom:20px; display:flex; align-items:center; justify-content:center; }
</style>


<section class="product-detail-section" dir="rtl">
  <div class="container" style="max-width:1200px; margin:0 auto; padding:0 24px;">
    <div class="row g-5">
      <div class="col-lg-7">
        <div class="image-gallery">
          <div class="thumbnails-col">
            <% const images = (product.images && product.images.length) ? product.images : (product.image ? [product.image] : []); %>
            <% images.forEach((img, idx) => { %>
              <button type="button" class="thumb-item <%= idx === 0 ? 'active' : '' %>" data-index="<%= idx %>"><img src="<%= img %>" alt="<%= product.name %>" /></button>
            <% }); %>
          </div>
          <div class="main-image-wrapper" id="imageSlider">
            <% images.forEach((img, idx) => { %>
              <img src="<%= img %>" alt="<%= product.name %>" class="main-image slider-img <%= idx === 0 ? 'active' : '' %>" style="<%= idx === 0 ? 'position:relative;opacity:1;' : 'position:absolute;opacity:0;' %>" />
            <% }); %>
            <button id="prevSlide" class="gallery-arrow left-arrow">&#10094;</button>
            <button id="nextSlide" class="gallery-arrow right-arrow">&#10095;</button>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="product-info-card">
          <span class="category-badge"><%= product.category === 'paint' ? 'دهان' : product.category === 'tools' ? 'أدوات' : 'إكسسوارات' %></span>
          <h1 class="product-title"><%= product.name %></h1>
          <div class="price-block"><span class="current-price"><%= product.price.toLocaleString('ar-DZ') %> دج</span></div>
          <div class="delivery-info">
            <div class="flex-item"><span style="width:10px;height:10px;background:#2c9814;border-radius:50%;display:inline-block;"></span><span>متوفر في المخزون – يُشحن في نفس اليوم</span></div>
            <div class="flex-item"><i class="fas fa-truck-fast" style="color:var(--accent-blue); margin-left:8px;"></i><span>توصيل مجاني لكل الولايات ابتداءً من 5000 دج</span></div>
          </div>
          <div class="quantity-selector">
            <span class="qty-label">الكمية :</span>
            <div class="qty-controls">
              <button type="button" id="qtyMinus" class="qty-btn">−</button>
              <input type="text" id="qtyInput" value="1" readonly class="qty-input" />
              <button type="button" id="qtyPlus" class="qty-btn">+</button>
            </div>
          </div>
          <button id="buyNowBtn" class="btn-buy-now"><i class="fas fa-bolt me-2"></i> اشتري الآن</button>
          <button id="whatsappBulkBtn" class="btn-whatsapp-bulk"><i class="fab fa-whatsapp me-2"></i> طلب بالجملة عبر واتساب</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const productName = '<%- product.name.replace(/'/g, "\\'") %>';
    const productPrice = <%= product.price %>;
    const productId   = '<%= product._id %>';

    // Gallery
    try {
      const imagesData = <%- JSON.stringify(typeof images !== 'undefined' ? images : []) %>;
      const slides = document.querySelectorAll('.slider-img');
      const thumbItems = document.querySelectorAll('.thumb-item');
      let currentIndex = 0;
      function setMainImage(index) {
        if (!imagesData.length) return;
        currentIndex = index;
        slides.forEach((s, i) => { s.style.opacity = i === index ? '1' : '0'; s.style.position = i === index ? 'relative' : 'absolute'; });
        thumbItems.forEach((t, i) => t.classList.toggle('active', i === index));
      }
      thumbItems.forEach(thumb => thumb.addEventListener('click', () => setMainImage(parseInt(thumb.dataset.index))));
      const prevBtn = document.getElementById('prevSlide');
      const nextBtn = document.getElementById('nextSlide');
      if (prevBtn) prevBtn.addEventListener('click', () => setMainImage((currentIndex - 1 + imagesData.length) % imagesData.length));
      if (nextBtn) nextBtn.addEventListener('click', () => setMainImage((currentIndex + 1) % imagesData.length));
    } catch (err) { console.error('Gallery failed', err); }

    // Qty
    const qtyInput = document.getElementById('qtyInput');
    const qtyMinus = document.getElementById('qtyMinus');
    const qtyPlus = document.getElementById('qtyPlus');
    if (qtyInput && qtyMinus && qtyPlus) {
      qtyMinus.addEventListener('click', () => { let val = parseInt(qtyInput.value) || 1; if (val > 1) qtyInput.value = val - 1; });
      qtyPlus.addEventListener('click', () => { let val = parseInt(qtyInput.value) || 1; qtyInput.value = val + 1; });
    }

    // VIEW CONTENT — FIXED FINAL: dedup with server eventID
    setTimeout(function() {
      try {
        if (typeof fbq !== 'undefined') {
          const serverEventId = '<%= typeof metaEventIdView !== "undefined" ? metaEventIdView : "" %>';
          if (serverEventId) {
            fbq('track', 'ViewContent', {
              content_name: productName,
              content_ids: [productId],
              content_type: 'product',
              value: productPrice,
              currency: 'DZD',
              contents: [{ id: productId, quantity: 1, item_price: productPrice }]
            }, { eventID: serverEventId });
            console.log('ViewContent dedup ID:', serverEventId);
          }
        }
      } catch (err) { console.warn('fbq ViewContent failed', err); }
    }, 1500);

    // BUY NOW — AddToCart dedup
    const buyNowBtn = document.getElementById('buyNowBtn');
    if (buyNowBtn) {
      buyNowBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
        buyNowBtn.innerHTML = 'جاري الإضافة…';
        buyNowBtn.disabled = true;
        try {
          if (typeof fbq !== 'undefined') {
            const serverEventId = '<%= typeof metaEventIdCart !== "undefined" ? metaEventIdCart : "" %>';
            if (serverEventId) {
              fbq('track', 'AddToCart', {
                content_name: productName,
                content_ids: [productId],
                content_type: 'product',
                value: productPrice * qty,
                currency: 'DZD',
                contents: [{ id: productId, quantity: qty, item_price: productPrice }]
              }, { eventID: serverEventId });
            }
          }
        } catch (err) { console.warn('fbq AddToCart failed', err); }
        setTimeout(() => {
          const eventIdParam = '<%= typeof metaEventIdCart !== "undefined" ? metaEventIdCart : "" %>';
          window.location.href = `/products/add-to-cart/${productId}?qty=${qty}&eventId=${encodeURIComponent(eventIdParam)}`;
        }, 200);
      });
    }
  });
</script>

<%- include('../../partials/footer') %>
