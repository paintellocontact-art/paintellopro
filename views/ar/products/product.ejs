
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<%
title: product.name + ' - Paintello Pro',

  metaEventIdView: typeof metaEventIdView !== 'undefined' ? metaEventIdView : '',
  metaEventIdCart: typeof metaEventIdCart !== 'undefined' ? metaEventIdCart : '',
  user: typeof user !== 'undefined' ? user : null,
  sessionPainter: typeof sessionPainter !== 'undefined' ? sessionPainter : null,
  whatsappPhone: typeof whatsappPhone !== 'undefined' ? whatsappPhone : '213796530868',

  const pixelId = typeof fbPixelId !== 'undefined' ? fbPixelId : process.env.FB_PIXEL_ID;
  const pageViewEventId = typeof metaEventIdPageView !== 'undefined' && metaEventIdPageView ? metaEventIdPageView : null;
  const advancedMatching = { country: 'dz' };
  if (typeof user !== 'undefined' && user) {
    if (user.email) advancedMatching.em = user.email;
    if (user.phone || user.numero) advancedMatching.ph = user.phone || user.numero;
    if (user.firstName) advancedMatching.fn = user.firstName;
    if (user.lastName) advancedMatching.ln = user.lastName;
  }
  if (typeof sessionPainter !== 'undefined' && sessionPainter) {
    if (!advancedMatching.em && sessionPainter.email) advancedMatching.em = sessionPainter.email;
    if (!advancedMatching.ph && sessionPainter.phone) advancedMatching.ph = sessionPainter.phone;
    if (!advancedMatching.fn && sessionPainter.firstName) advancedMatching.fn = sessionPainter.firstName;
    else if (!advancedMatching.fn && sessionPainter.name) advancedMatching.fn = sessionPainter.name;
    if (!advancedMatching.ln && sessionPainter.lastName) advancedMatching.ln = sessionPainter.lastName;
  }
%>
<% if (pixelId) { %>
<script>
