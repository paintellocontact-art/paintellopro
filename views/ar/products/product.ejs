<%- include('../../partials/header', { 
  title: product.name + ' - Paintello Pro',
  metaEventIdPageView: typeof metaEventIdPageView !== 'undefined' ? metaEventIdPageView : '',
  metaEventIdView: typeof metaEventIdView !== 'undefined' ? metaEventIdView : '',
  metaEventIdCart: typeof metaEventIdCart !== 'undefined' ? metaEventIdCart : '',
  user: typeof user !== 'undefined' ? user : null,
  sessionPainter: typeof sessionPainter !== 'undefined' ? sessionPainter : null,
  whatsappPhone: typeof whatsappPhone !== 'undefined' ? whatsappPhone : '213796530868'
}) %>

<style>
/* ===== BM STORE STYLE - CLEAN MINIMAL ===== */
:root {
  --bm-black: #111111;
  --bm-gray-900: #1a1a1a;
  --bm-gray-700: #4a4a4a;
  --bm-gray-500: #8a8a8a;
  --bm-gray-200: #eeeeee;
  --bm-gray-100: #f6f6f6;
  --bm-white: #ffffff;
  --bm-green: #00a650;
  --bm-red: #e10600;
}
body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bm-white); color: var(--bm-black); }
.bm-breadcrumb { font-size: 0.8rem; color: var(--bm-gray-500); margin-bottom: 20px; }
.bm-breadcrumb a { color: var(--bm-gray-500); text-decoration: none; }
.bm-breadcrumb a:hover { color: var(--bm-black); }

.bm-product-layout { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 50px; max-width: 1280px; margin: 0 auto; padding: 30px 24px 60px; }
@media (max-width: 992px) { .bm-product-layout { grid-template-columns: 1fr; gap: 30px; } }

/* Gallery BM Style */
.bm-gallery { display: flex; gap: 16px; }
.bm-thumbs { display: flex; flex-direction: column; gap: 10px; }
.bm-thumb { width: 72px; height: 72px; border: 1px solid var(--bm-gray-200); background: var(--bm-white); cursor: pointer; padding: 4px; transition: all .2s; }
.bm-thumb.active { border-color: var(--bm-black); }
.bm-thumb img { width: 100%; height: 100%; object-fit: contain; }
.bm-main-wrap { flex: 1; background: var(--bm-gray-100); position: relative; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; overflow: hidden; cursor: zoom-in; }
.bm-main-img { max-width: 85%; max-height: 85%; object-fit: contain; transition: opacity .3s; position: absolute; }
.bm-gallery-arrow { position: absolute; top: 50%; transform: translateY(-50%); background: var(--bm-white); border: 1px solid var(--bm-gray-200); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; opacity: 0; transition: .2s; }
.bm-main-wrap:hover .bm-gallery-arrow { opacity: 1; }
.bm-arrow-left { left: 12px; } .bm-arrow-right { right: 12px; }
.bm-badge-stock { position: absolute; top: 12px; left: 12px; background: var(--bm-black); color: var(--bm-white); font-size: 0.7rem; padding: 4px 8px; letter-spacing: .5px; text-transform: uppercase; }

/* Info BM Style */
.bm-info { position: sticky; top: 90px; }
.bm-brand { font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; color: var(--bm-gray-500); margin-bottom: 8px; }
.bm-title { font-size: 2rem; font-weight: 700; line-height: 1.2; margin-bottom: 12px; color: var(--bm-black); }
.bm-rating { display: flex; align-items: center; gap: 6px; font-size: 0.85rem; color: var(--bm-gray-500); margin-bottom: 18px; }
.bm-price-row { display: flex; align-items: baseline; gap: 12px; margin-bottom: 20px; }
.bm-price { font-size: 2rem; font-weight: 800; color: var(--bm-black); }
.bm-old-price { font-size: 1rem; color: var(--bm-gray-500); text-decoration: line-through; }
.bm-stock { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; color: var(--bm-green); background: #e6f6ee; padding: 6px 10px; border-radius: 20px; margin-bottom: 20px; }
.bm-dot { width: 8px; height: 8px; background: var(--bm-green); border-radius: 50%; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }

/* BM Quantity + Buttons */
.bm-qty-row { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }
.bm-qty-box { display: flex; align-items: center; border: 1px solid var(--bm-black); height: 48px; }
.bm-qty-btn { width: 48px; height: 48px; border: none; background: var(--bm-white); font-size: 1.2rem; cursor: pointer; }
.bm-qty-btn:hover { background: var(--bm-gray-100); }
.bm-qty-input { width: 56px; text-align: center; border: none; border-left: 1px solid var(--bm-black); border-right: 1px solid var(--bm-black); height: 48px; font-weight: 600; }
.bm-btn { width: 100%; height: 52px; border: 1px solid var(--bm-black); font-weight: 700; letter-spacing: .5px; text-transform: uppercase; font-size: 0.9rem; cursor: pointer; transition: .2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
.bm-btn-primary { background: var(--bm-black); color: var(--bm-white); margin-bottom: 10px; }
.bm-btn-primary:hover { background: var(--bm-gray-900); transform: translateY(-1px); }
.bm-btn-secondary { background: var(--bm-white); color: var(--bm-black); margin-bottom: 20px; }
.bm-btn-secondary:hover { background: var(--bm-black); color: var(--bm-white); }
.bm-delivery { background: var(--bm-gray-100); padding: 16px; font-size: 0.85rem; line-height: 1.6; margin-bottom: 20px; }
.bm-delivery b { color: var(--bm-black); }

/* Tabs BM */
.bm-tabs { border-top: 1px solid var(--bm-gray-200); margin-top: 24px; }
.bm-tab-head { display: flex; gap: 24px; border-bottom: 1px solid var(--bm-gray-200); overflow-x: auto; }
.bm-tab-btn { background: none; border: none; padding: 14px 0; font-weight: 600; font-size: 0.9rem; color: var(--bm-gray-500); border-bottom: 2px solid transparent; cursor: pointer; white-space: nowrap; }
.bm-tab-btn.active { color: var(--bm-black); border-bottom-color: var(--bm-black); }
.bm-tab-pane { display: none; padding: 20px 0; font-size: 0.92rem; line-height: 1.8; color: var(--bm-gray-700); }
.bm-tab-pane.active { display: block; }

/* Related BM */
.bm-related { max-width: 1280px; margin: 0 auto; padding: 40px 24px; border-top: 1px solid var(--bm-gray-200); }
.bm-related h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 20px; }
.bm-carousel { display: flex; gap: 16px; overflow-x: auto; scroll-behavior: smooth; scrollbar-width: none; }
.bm-carousel::-webkit-scrollbar { display: none; }
.bm-card { min-width: 200px; max-width: 200px; border: 1px solid var(--bm-gray-200); background: var(--bm-white); text-decoration: none; color: inherit; }
.bm-card-img { background: var(--bm-gray-100); aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; padding: 16px; }
.bm-card-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
.bm-card-body { padding: 12px; }
.bm-card-name { font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.bm-card-price { font-weight: 700; font-size: 0.9rem; }

/* Lightbox BM */
.bm-lightbox { position: fixed; inset: 0; background: rgba(255,255,255,0.98); display: none; align-items: center; justify-content: center; z-index: 9999; }
.bm-lightbox.active { display: flex; }
.bm-lightbox img { max-width: 90%; max-height: 90%; object-fit: contain; }
.bm-lightbox-close, .bm-lightbox-nav { position: absolute; background: var(--bm-black); color: var(--bm-white); border: none; width: 44px; height: 44px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.bm-lightbox-close { top: 20px; right: 20px; }
.bm-lightbox-prev { left: 20px; top: 50%; transform: translateY(-50%); }
.bm-lightbox-next { right: 20px; top: 50%; transform: translateY(-50%); }

/* Video full bleed BM */
.bm-video { width: 100vw; margin-left: calc(-50vw + 50%); background: #000; aspect-ratio: 16/9; position: relative; margin-top: 40px; margin-bottom: 40px; }
.bm-video iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }
</style>

<div class="bm-product-layout" dir="rtl">
  <!-- LEFT: Gallery -->
  <div class="bm-gallery">
    <div class="bm-thumbs">
      <% const images = (product.images && product.images.length) ? product.images : (product.image ? [product.image] : []); %>
      <% images.forEach((img, idx) => { %>
        <button type="button" class="bm-thumb <%= idx===0?'active':'' %>" data-index="<%= idx %>"><img src="<%= img %>" alt="<%= product.name %>"></button>
      <% }); %>
    </div>
    <div class="bm-main-wrap" id="bmSlider">
      <span class="bm-badge-stock">En stock</span>
      <% images.forEach((img, idx) => { %>
        <img src="<%= img %>" alt="<%= product.name %>" class="bm-main-img" data-index="<%= idx %>" style="opacity:<%= idx===0?1:0 %>;position:<%= idx===0?'relative':'absolute' %>">
      <% }); %>
      <button class="bm-gallery-arrow bm-arrow-left" id="bmPrev">&#10094;</button>
      <button class="bm-gallery-arrow bm-arrow-right" id="bmNext">&#10095;</button>
    </div>
  </div>

  <!-- RIGHT: Info -->
  <div class="bm-info">
    <div class="bm-breadcrumb"><a href="/">Accueil</a> / <a href="/products/ar">Boutique</a> / <%= product.name %></div>
    <div class="bm-brand"><%= product.category ? product.category.toUpperCase() : 'PAINTELLO PRO' %></div>
    <h1 class="bm-title"><%= product.name %></h1>
    <div class="bm-rating"><span>★★★★★</span> <span>(12 avis)</span> <span style="color:var(--bm-green);">• En stock</span></div>
    <div class="bm-price-row">
      <span class="bm-price"><%= product.price.toLocaleString('fr-DZ') %> DA</span>
      <% if (product.oldPrice && product.oldPrice > product.price) { %><span class="bm-old-price"><%= product.oldPrice.toLocaleString('fr-DZ') %> DA</span><% } %>
    </div>
    <div class="bm-stock"><span class="bm-dot"></span> Disponible - Expédition immédiate</div>

    <div class="bm-qty-row">
      <span style="font-weight:600;font-size:.9rem;">Quantité:</span>
      <div class="bm-qty-box">
        <button class="bm-qty-btn" id="bmMinus">−</button>
        <input id="bmQty" class="bm-qty-input" value="1" readonly>
        <button class="bm-qty-btn" id="bmPlus">+</button>
      </div>
    </div>

    <button id="bmBuyNow" class="bm-btn bm-btn-primary"><i class="fas fa-bolt"></i> Acheter maintenant</button>
    <button id="bmWhatsApp" class="bm-btn bm-btn-secondary"><i class="fab fa-whatsapp"></i> Commander sur WhatsApp</button>

    <div class="bm-delivery">
      <div><b>🚚 Livraison gratuite</b> à partir de 5000 DA - Toutes wilayas</div>
      <div><b>↩️ Retour gratuit</b> sous 4 jours - Garantie 100%</div>
      <div><b>💳 Paiement</b> à la livraison ou CIB / Edahabia</div>
    </div>

    <div class="bm-tabs">
      <div class="bm-tab-head">
        <button class="bm-tab-btn active" data-tab="bmDesc">Description</button>
        <button class="bm-tab-btn" data-tab="bmSpecs">Caractéristiques</button>
        <button class="bm-tab-btn" data-tab="bmShip">Livraison</button>
        <button class="bm-tab-btn" data-tab="bmGuarantee">Garantie</button>
      </div>
      <div id="bmDesc" class="bm-tab-pane active"><%= product.description || 'Description détaillée du produit...' %></div>
      <div id="bmSpecs" class="bm-tab-pane">
        <% if (product.specifications && product.specifications.length) { %>
          <% product.specifications.forEach(s=>{ %><div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #eee;"><span style="color:#888;"><%= s.key %></span><b><%= s.value %></b></div><% }) %>
        <% } else { %> <p>Aucune spécification disponible.</p> <% } %>
      </div>
      <div id="bmShip" class="bm-tab-pane">Livraison standard 3-5 jours, express 1-2 jours. Expédition le jour même avant 14h.</div>
      <div id="bmGuarantee" class="bm-tab-pane">Garantie 4 jours satisfait ou remboursé. Produit contrôlé avant envoi.</div>
    </div>
  </div>
</div>

<% if (product.videoFile || product.videoId) { %>
<div class="bm-video">
  <iframe src="<%= product.videoFile ? product.videoFile : 'https://www.youtube.com/embed/'+product.videoId+'?rel=0' %>" allow="autoplay; fullscreen" allowfullscreen></iframe>
</div>
<% } %>

<% if (typeof relatedProducts !== 'undefined' && relatedProducts.length) { %>
<div class="bm-related" dir="rtl">
  <h2>Vous aimerez aussi</h2>
  <div class="bm-carousel" id="bmRelated">
    <% relatedProducts.forEach(rp=>{ %>
      <a href="/products/<%= rp._id %>" class="bm-card">
        <div class="bm-card-img"><img src="<%= (rp.images && rp.images[0]) ? rp.images[0] : rp.image %>" alt="<%= rp.name %>"></div>
        <div class="bm-card-body"><div class="bm-card-name"><%= rp.name %></div><div class="bm-card-price"><%= rp.price.toLocaleString('fr-DZ') %> DA</div></div>
      </a>
    <% }) %>
  </div>
</div>
<% } %>

<div class="bm-lightbox" id="bmLightbox">
  <button class="bm-lightbox-close" id="bmLbClose"><i class="fas fa-times"></i></button>
  <button class="bm-lightbox-nav bm-lightbox-prev" id="bmLbPrev">&#10094;</button>
  <button class="bm-lightbox-nav bm-lightbox-next" id="bmLbNext">&#10095;</button>
  <img id="bmLbImg" src="">
</div>

<script>
document.addEventListener('DOMContentLoaded', function(){
  const productName = '<%- product.name.replace(/'/g, "\\'") %>';
  const productPrice = <%= product.price %>;
  const productId = '<%= product._id %>';
  const images = <%- JSON.stringify(typeof images !== 'undefined' ? images : []) %>;
  let idx = 0;
  const mainImgs = document.querySelectorAll('.bm-main-img');
  const thumbs = document.querySelectorAll('.bm-thumb');
  function show(i){
    if(!images.length) return;
    idx = (i+images.length)%images.length;
    mainImgs.forEach((img,k)=>{ img.style.opacity = k===idx?1:0; img.style.position = k===idx?'relative':'absolute'; });
    thumbs.forEach((t,k)=> t.classList.toggle('active', k===idx));
  }
  thumbs.forEach(t=> t.addEventListener('click', ()=> show(parseInt(t.dataset.index))));
  document.getElementById('bmPrev')?.addEventListener('click', ()=> show(idx-1));
  document.getElementById('bmNext')?.addEventListener('click', ()=> show(idx+1));
  
  // Swipe
  const slider = document.getElementById('bmSlider');
  let startX=0;
  slider.addEventListener('touchstart', e=> startX=e.touches[0].clientX);
  slider.addEventListener('touchend', e=> { const diff=e.changedTouches[0].clientX-startX; if(Math.abs(diff)>50) show(diff>0?idx-1:idx+1); });

  // Lightbox - FIXED
  const lb = document.getElementById('bmLightbox');
  const lbImg = document.getElementById('bmLbImg');
  function openLb(){ if(images.length){ lbImg.src=images[idx]; lb.classList.add('active'); document.body.style.overflow='hidden'; } }
  function closeLb(){ lb.classList.remove('active'); document.body.style.overflow=''; }
  slider.addEventListener('click', openLb);
  document.getElementById('bmLbClose')?.addEventListener('click', closeLb);
  document.getElementById('bmLbPrev')?.addEventListener('click', ()=>{ show(idx-1); lbImg.src=images[idx]; });
  document.getElementById('bmLbNext')?.addEventListener('click', ()=>{ show(idx+1); lbImg.src=images[idx]; });
  lb.addEventListener('click', e=> { if(e.target===lb) closeLb(); });
  document.addEventListener('keydown', e=> { if(e.key==='Escape') closeLb(); if(lb.classList.contains('active')){ if(e.key==='ArrowLeft'){ show(idx-1); lbImg.src=images[idx]; } if(e.key==='ArrowRight'){ show(idx+1); lbImg.src=images[idx]; } } });

  // Qty
  const qtyInput = document.getElementById('bmQty');
  document.getElementById('bmMinus')?.addEventListener('click', ()=> { let v=parseInt(qtyInput.value)||1; if(v>1) qtyInput.value=v-1; });
  document.getElementById('bmPlus')?.addEventListener('click', ()=> { let v=parseInt(qtyInput.value)||1; qtyInput.value=v+1; });

  // Tabs
  document.querySelectorAll('.bm-tab-btn').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      document.querySelectorAll('.bm-tab-btn').forEach(b=> b.classList.remove('active'));
      document.querySelectorAll('.bm-tab-pane').forEach(p=> p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(btn.dataset.tab)?.classList.add('active');
    });
  });

  // 🎯 Pixel - SAME AS HOME
  setTimeout(()=>{
    try{
      const eid = '<%= typeof metaEventIdView !== "undefined" ? metaEventIdView : "" %>';
      if(typeof fbq!=='undefined' && eid){
        fbq('track','ViewContent',{ content_name: productName, content_ids:[productId], content_type:'product', value: productPrice, currency:'DZD', contents:[{id:productId, quantity:1, item_price:productPrice}] }, {eventID: eid});
        console.log('🎯 ViewContent BM:', eid);
      }
    }catch(e){}
  },2000);

  // Buy Now
  document.getElementById('bmBuyNow')?.addEventListener('click', function(e){
    e.preventDefault();
    const qty = parseInt(qtyInput.value)||1;
    this.innerHTML='جاري الإضافة…'; this.disabled=true;
    try{
      const eid='<%= typeof metaEventIdCart !== "undefined" ? metaEventIdCart : "" %>';
      if(typeof fbq!=='undefined' && eid){
        fbq('track','AddToCart',{ content_name: productName, content_ids:[productId], content_type:'product', value: productPrice*qty, currency:'DZD', contents:[{id:productId, quantity:qty, item_price:productPrice}] }, {eventID: eid});
      }
    }catch(e){}
    setTimeout(()=>{ const eid='<%= typeof metaEventIdCart !== "undefined" ? metaEventIdCart : "" %>'; window.location.href='/products/add-to-cart/'+productId+'?qty='+qty+'&eventId='+encodeURIComponent(eid); },150);
  });

  // WhatsApp
  document.getElementById('bmWhatsApp')?.addEventListener('click', ()=>{
    const phone='<%= typeof whatsappPhone !== "undefined" ? whatsappPhone : "213796530868" %>';
    const text=encodeURIComponent('مرحبا Paintello، أنا مهتم بـ "'+productName+'" بسعر '+productPrice+' DA');
    window.open('https://wa.me/'+phone+'?text='+text,'_blank');
  });
});
</script>

<%- include('../../partials/footer') %>
