<%- include('../../partials/header', { 
  title: product.name + ' - Paintello Pro',
  metaEventIdPageView: typeof metaEventIdPageView !== 'undefined' ? metaEventIdPageView : '',
  metaEventIdView: typeof metaEventIdView !== 'undefined' ? metaEventIdView : '',
  metaEventIdCart: typeof metaEventIdCart !== 'undefined' ? metaEventIdCart : '',
  user: typeof user !== 'undefined' ? user : null,
  sessionPainter: typeof sessionPainter !== 'undefined' ? sessionPainter : null,
  whatsappPhone: typeof whatsappPhone !== 'undefined' ? whatsappPhone : '213796530868'
}) %>

<style>
  :root { --primary-blue:#295797; --accent-blue:#1C84C1; --primary-dark:#1E3F5C; --text-dark:#2D3748; --text-gray:#4A5568; --bg-light:#E8EEF6; --bg-white:#FFFFFF; --border-light:#D1DCE6; }
  body { font-family:'Tajawal','Cairo',sans-serif; background:var(--bg-light); }
  .product-detail-section { padding:20px 0 80px; }
  .image-gallery { display:flex; gap:12px; margin-bottom:12px; }
  .thumbnails-col { display:flex; flex-direction:column; gap:8px; max-height:480px; overflow-y:auto; scrollbar-width:none; }
  .thumb-item { width:68px; height:68px; border:2px solid transparent; border-radius:10px; overflow:hidden; cursor:pointer; background:#fff; padding:0; flex-shrink:0; }
  .thumb-item.active { border-color:var(--primary-blue); }
  .thumb-item img { width:100%; height:100%; object-fit:cover; display:block; }
  .main-image-wrapper { flex:1; position:relative; background:#fff; border-radius:20px; border:1px solid var(--border-light); display:flex; align-items:center; justify-content:center; min-height:440px; overflow:hidden; cursor:zoom-in; }
  .main-image { max-width:100%; max-height:480px; object-fit:contain; padding:16px; pointer-events:none; }
  .gallery-arrow { position:absolute; top:50%; transform:translateY(-50%); background:rgba(0,0,0,0.45); color:#fff; border:none; width:38px; height:38px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center; z-index:2; }
  .left-arrow{left:10px} .right-arrow{right:10px}
  .gallery-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; }
  .gallery-item { border-radius:10px; overflow:hidden; cursor:pointer; border:1px solid var(--border-light); background:#fff; }
  .gallery-item img { width:100%; height:86px; object-fit:cover; display:block; }
  .product-info-card { background:#fff; border-radius:20px; padding:24px; border:1px solid var(--border-light); }
  .category-badge { background:rgba(41,87,151,0.1); color:var(--primary-blue); padding:4px 12px; border-radius:20px; font-size:0.8rem; font-weight:600; display:inline-block; margin-bottom:10px; }
  .product-title { font-size:1.8rem; font-weight:800; line-height:1.3; margin-bottom:10px; }
  .price-block { display:flex; align-items:center; gap:12px; margin-bottom:12px; }
  .current-price { font-size:2rem; font-weight:800; color:var(--primary-blue); }
  .stock-badge { background:#e6f6ee; color:#0a7a3d; padding:6px 10px; border-radius:20px; font-size:0.8rem; display:inline-flex; align-items:center; gap:6px; }
  .urgency-bar { background:#fff7ed; border:1px dashed #f59e0b; border-radius:12px; padding:10px 14px; font-size:0.85rem; margin:14px 0; display:flex; align-items:center; justify-content:space-between; }
  .social-proof { display:flex; align-items:center; gap:8px; font-size:0.82rem; color:var(--text-gray); margin-bottom:14px; }
  .social-proof .avatars { display:flex; } .social-proof .avatars span { width:22px; height:22px; border-radius:50%; background:var(--primary-blue); color:#fff; display:flex; align-items:center; justify-content:center; font-size:0.7rem; border:2px solid #fff; margin-left:-6px; }
  .quantity-selector { display:flex; align-items:center; gap:10px; margin:16px 0; }
  .qty-controls { display:flex; align-items:center; border:1px solid var(--border-light); border-radius:30px; overflow:hidden; }
  .qty-btn { width:40px; height:40px; border:none; background:#f8fafc; cursor:pointer; font-size:1.1rem; } .qty-btn:active{transform:scale(0.95);}
  .qty-input { width:48px; text-align:center; border:none; font-weight:700; background:#fff; }
  .btn-buy-now { width:100%; background:var(--primary-blue); color:#fff; border:none; padding:15px; border-radius:50px; font-weight:800; font-size:1.05rem; display:flex; align-items:center; justify-content:center; gap:8px; cursor:pointer; }
  .btn-buy-now:disabled { opacity:0.6; cursor:not-allowed; }
  .btn-whatsapp-bulk { width:100%; background:#25D366; color:#fff; border:none; padding:13px; border-radius:50px; font-weight:600; margin-top:10px; display:flex; align-items:center; justify-content:center; gap:8px; cursor:pointer; }
  .trust-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:16px; text-align:center; font-size:0.75rem; color:var(--text-gray); }
  .trust-row i { display:block; font-size:1.2rem; color:var(--primary-blue); margin-bottom:4px; }
  /* Tabs */
  .nav-tabs .nav-link { border:none; color:var(--text-gray); } .nav-tabs .nav-link.active{color:var(--primary-blue);border-bottom:2px solid var(--primary-blue);background:transparent;font-weight:700;}
  /* Sticky buy for social ghosting */
  .sticky-buy { position:fixed; bottom:0; left:0; right:0; background:#fff; border-top:1px solid var(--border-light); padding:10px 16px; display:none; align-items:center; justify-content:space-between; z-index:9998; box-shadow:0 -4px 20px rgba(0,0,0,0.08); }
  .sticky-buy.show { display:flex; }
  .sticky-buy img { width:48px; height:48px; border-radius:8px; object-fit:cover; }
  .sticky-buy .btn { background:var(--primary-blue); color:#fff; border:none; padding:10px 20px; border-radius:30px; font-weight:700; cursor:pointer; }
  @media(max-width:768px){ .image-gallery{flex-direction:column-reverse;} .thumbnails-col{flex-direction:row; max-height:none;} .thumb-item{width:56px;height:56px;} }

  /* BM WHITE LIGHTBOX - no JS errors */
  .lightbox-backdrop{position:fixed;inset:0;background:rgba(255,255,255,0.98);display:none;align-items:center;justify-content:center;z-index:99999;opacity:0;transition:opacity .25s;}
  .lightbox-backdrop.active{display:flex;opacity:1;}
  .lightbox-close{position:absolute;top:16px;right:16px;background:#111;color:#fff;border:none;width:44px;height:44px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:100000;}
  .lightbox-nav{position:absolute;top:50%;transform:translateY(-50%);background:#fff;color:#111;border:1px solid #111;width:44px;height:44px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:100000;}
  .lightbox-prev{left:16px;} .lightbox-next{right:16px;}
  .lightbox-image{max-width:92vw;max-height:92vh;object-fit:contain;}
</style>

<section class="product-detail-section" dir="rtl">
  <div class="container" style="max-width:1200px;margin:0 auto;padding:0 16px;">
    <!-- Trust bar for social traffic -->
    <div style="background:#111;color:#fff;text-align:center;padding:8px;font-size:0.8rem;border-radius:8px;margin-bottom:16px;">🚚 توصيل مجاني من 7000 دج | ⏰ اطلب قبل 14:00 يُشحن اليوم | 🔒 دفع عند الاستلام</div>
    <div class="row g-4">
      <div class="col-lg-7">
        <div class="image-gallery">
          <div class="thumbnails-col" id="thumbsCol">
            <% const images = (product.images && product.images.length) ? product.images : (product.image ? [product.image] : ['/img/placeholder.png']); %>
            <% images.forEach((img, idx) => { %>
              <button type="button" class="thumb-item <%= idx===0?'active':'' %>" data-index="<%= idx %>" aria-label="View image <%= idx+1 %>"><img src="<%= img %>" alt="<%= product.name %>" loading="<%= idx===0?'eager':'lazy' %>" onerror="this.src='/img/placeholder.png'"></button>
            <% }); %>
          </div>
          <div class="main-image-wrapper" id="imageSlider" role="button" tabindex="0" aria-label="Open fullscreen">
            <% images.forEach((img, idx) => { %>
              <img src="<%= img %>" alt="<%= product.name %>" class="main-image" data-index="<%= idx %>" style="position:<%= idx===0?'relative':'absolute' %>;opacity:<%= idx===0?'1':'0' %>;" loading="eager" onerror="this.style.display='none'">
            <% }); %>
            <button type="button" class="gallery-arrow left-arrow" id="prevSlide" aria-label="Previous">&#10094;</button>
            <button type="button" class="gallery-arrow right-arrow" id="nextSlide" aria-label="Next">&#10095;</button>
          </div>
        </div>
        <div class="gallery-grid">
          <% images.slice(0,4).forEach((img, idx) => { %><div class="gallery-item" data-index="<%= idx %>" role="button" tabindex="0"><img src="<%= img %>" alt="" loading="lazy"></div><% }); %>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="product-info-card">
          <span class="category-badge"><%= product.category || 'منتج' %></span>
          <h1 class="product-title"><%= product.name %></h1>
          <div class="social-proof"><div class="avatars"><span>★</span><span style="background:#25D366;">✓</span><span style="background:#f59e0b;">A</span></div><span>🔥 <b id="viewCount">23</b> شخص يشاهد هذا الآن • <b>4.9/5</b> (127 تقييم)</span></div>
          <div class="price-block"><span class="current-price"><%= product.price.toLocaleString('ar-DZ') %> دج</span><span class="stock-badge"><span style="width:8px;height:8px;background:#0a7a3d;border-radius:50%;display:inline-block;"></span> متوفر</span></div>
          <div class="urgency-bar"><span>⏳ العرض ينتهي خلال: <b id="countdown">02:14:33</b></span><span style="color:#d97706;">تبقى 7 قطع فقط!</span></div>
          <div class="quantity-selector"><span style="font-weight:700;">الكمية:</span><div class="qty-controls"><button type="button" class="qty-btn" id="qtyMinus" aria-label="Decrease">−</button><input id="qtyInput" class="qty-input" value="1" readonly><button type="button" class="qty-btn" id="qtyPlus" aria-label="Increase">+</button></div></div>
          <button type="button" id="buyNowBtn" class="btn-buy-now"><i class="fas fa-bolt"></i> اشتري الآن - الدفع عند الاستلام</button>
          <button type="button" id="whatsappBulkBtn" class="btn-whatsapp-bulk"><i class="fab fa-whatsapp"></i> استفسار جملة عبر واتساب</button>
          <div class="trust-row"><div><i class="fas fa-truck"></i>توصيل 69 ولاية</div><div><i class="fas fa-undo"></i>إرجاع 4 أيام</div><div><i class="fas fa-shield-alt"></i>دفع آمن</div></div>
          <div class="product-tabs mt-4">
            <ul class="nav nav-tabs" role="tablist"><li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#desc" type="button">الوصف</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#delivery" type="button">التوصيل</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#guarantee" type="button">الضمان</button></li></ul>
            <div class="tab-content mt-3"><div class="tab-pane fade show active" id="desc"><p><%= product.description || '' %></p></div><div class="tab-pane fade" id="delivery"><p>توصيل مجاني من 7000 دج. شحن نفس اليوم قبل 14:00.</p></div><div class="tab-pane fade" id="guarantee"><p>ضمان 4 أيام استرجاع كامل.</p></div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ===== FULL-WIDTH CLOUDINARY VIDEO (kept) ===== -->
<% if (product.videoFile) { %>
<section class="product-video-fullbleed" dir="rtl" style="margin:40px 0;">
  <div style="width:100vw;position:relative;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;">
    <div style="max-width:1200px;margin:0 auto;padding:0 16px;text-align:center;margin-bottom:20px;">
      <p style="font-size:0.75rem;letter-spacing:2px;color:#4A5568;">المنتج في حركة</p>
      <h2 style="font-size:1.8rem;font-weight:300;">الحركة تكشف التفاصيل</h2>
    </div>
    <div style="position:relative;width:100%;background:#000;aspect-ratio:16/9;">
      <iframe src="<%= product.videoFile %>" frameborder="0" allow="autoplay; fullscreen; encrypted-media; picture-in-picture" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"></iframe>
    </div>
  </div>
</section>
<% } %>

<!-- ===== FULL-WIDTH YOUTUBE VIDEO (kept) ===== -->
<% if (product.videoId) { %>
<section class="product-video-fullbleed" dir="rtl" style="margin:40px 0;">
  <div style="width:100vw;position:relative;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;">
    <div style="max-width:1200px;margin:0 auto;padding:0 16px;text-align:center;margin-bottom:20px;">
      <p style="font-size:0.75rem;letter-spacing:2px;color:#4A5568;">فيديو توضيحي</p>
      <h2 style="font-size:1.8rem;font-weight:300;">شاهد المنتج عن قرب</h2>
      <p style="font-size:0.95rem;color:#4A5568;max-width:500px;margin:8px auto 0;">فيديو يوضح مميزات المنتج وطريقة استخدامه.</p>
    </div>
    <div style="position:relative;width:100%;background:#000;aspect-ratio:16/9;">
      <iframe src="https://www.youtube.com/embed/<%= product.videoId %>?rel=0&playsinline=1" frameborder="0" allow="accelerometer; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"></iframe>
    </div>
  </div>
</section>
<% } %>

<% if (typeof relatedProducts !== 'undefined' && relatedProducts.length > 0) { %>
<section class="related-products-section" dir="rtl" style="padding:40px 0;background:#fff;border-top:1px solid #D1DCE6;">
  <div class="container" style="max-width:1200px;margin:0 auto;padding:0 16px;">
    <h2 style="font-size:1.6rem;font-weight:700;margin-bottom:20px;">منتجات قد تعجبك</h2>
    <div style="display:flex;gap:16px;overflow-x:auto;scroll-behavior:smooth;padding:10px 0;">
      <% relatedProducts.forEach(rp => { %>
        <a href="/products/<%= rp._id %>" style="flex:0 0 200px;background:#fff;border-radius:16px;border:1px solid #D1DCE6;overflow:hidden;text-decoration:none;color:inherit;">
          <div style="height:160px;background:#E8EEF6;display:flex;align-items:center;justify-content:center;"><img src="<%= (rp.images && rp.images[0]) ? rp.images[0] : rp.image %>" alt="<%= rp.name %>" style="max-height:100%;max-width:100%;object-fit:contain;"></div>
          <div style="padding:12px;text-align:center;"><div style="font-weight:600;font-size:0.9rem;margin-bottom:4px;"><%= rp.name %></div><span style="color:#295797;font-weight:700;"><%= rp.price.toLocaleString('ar-DZ') %> دج</span></div>
        </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- Sticky buy for social ghosting -->
<div class="sticky-buy" id="stickyBuy" dir="rtl">
  <div style="display:flex;align-items:center;gap:10px;"><img id="stickyImg" src="<%= images[0] %>" alt=""><div><div style="font-weight:700;font-size:0.9rem;"><%= product.name.length>30? product.name.slice(0,30)+'...':product.name %></div><div style="color:var(--primary-blue);font-weight:800;"><%= product.price.toLocaleString('ar-DZ') %> دج</div></div></div>
  <button type="button" class="btn" id="stickyBuyBtn">اشتري الآن</button>
</div>

<!-- White Lightbox -->
<div id="lightbox" class="lightbox-backdrop" aria-hidden="true">
  <button type="button" id="lightboxClose" class="lightbox-close" aria-label="Close"><i class="fas fa-times"></i></button>
  <button type="button" id="lightboxPrev" class="lightbox-nav lightbox-prev" aria-label="Previous">&#10094;</button>
  <button type="button" id="lightboxNext" class="lightbox-nav lightbox-next" aria-label="Next">&#10095;</button>
  <img id="lightboxImage" src="" alt="" class="lightbox-image">
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function(){
  // Safe guard - no JS errors even if product has 1 image
  const imagesData = (()=>{ try{ return <%- JSON.stringify(typeof images !== 'undefined' ? images : []) %>; }catch(e){ return []; } })() || [];
  if(!imagesData.length) return;
  let currentIndex = 0;
  const $ = sel => document.querySelector(sel);
  const $$ = sel => Array.from(document.querySelectorAll(sel));
  const slides = $$('.main-image');
  const thumbs = $$('.thumb-item');
  const galleryItems = $$('.gallery-item');

  function setMainImage(idx){
    try{
      if(!imagesData.length) return;
      currentIndex = (idx + imagesData.length) % imagesData.length;
      slides.forEach((s,i)=>{ s.style.opacity = i===currentIndex?'1':'0'; s.style.position = i===currentIndex?'relative':'absolute'; });
      thumbs.forEach((t,i)=> t.classList.toggle('active', i===currentIndex));
    }catch(e){ console.warn('setMainImage error', e); }
  }
  window.setMainImage = setMainImage;

  // Thumbs click - fixes dead clicks
  thumbs.forEach(t=>{ t.addEventListener('click', ()=>{ const i=parseInt(t.dataset.index); if(!isNaN(i)) setMainImage(i); }); });
  galleryItems.forEach(g=>{ g.addEventListener('click', ()=>{ const i=parseInt(g.dataset.index); if(!isNaN(i)) setMainImage(i); }); });
  $('#prevSlide')?.addEventListener('click', e=>{ e.stopPropagation(); setMainImage(currentIndex-1); });
  $('#nextSlide')?.addEventListener('click', e=>{ e.stopPropagation(); setMainImage(currentIndex+1); });

  // Swipe main
  const slider = $('#imageSlider');
  if(slider){
    let sx=0;
    slider.addEventListener('touchstart', e=>{ sx=e.touches[0].clientX; }, {passive:true});
    slider.addEventListener('touchend', e=>{ const dx=e.changedTouches[0].clientX-sx; if(Math.abs(dx)>40) setMainImage(dx>0?currentIndex-1:currentIndex+1); }, {passive:true});
    slider.addEventListener('click', e=>{ if(e.target.closest('.gallery-arrow')) return; openLb(); });
  }

  // Lightbox - BM white + ESC/arrows/swipe - no errors
  const lb = $('#lightbox');
  const lbImg = $('#lightboxImage');
  function openLb(){ try{ if(!imagesData[currentIndex]) return; lbImg.src=imagesData[currentIndex]; lb.classList.add('active'); document.body.style.overflow='hidden'; lb.setAttribute('aria-hidden','false'); }catch(e){} }
  function closeLb(){ lb.classList.remove('active'); document.body.style.overflow=''; lb.setAttribute('aria-hidden','true'); }
  $('#openLightboxBtn')?.addEventListener('click', openLb);
  $('#lightboxClose')?.addEventListener('click', closeLb);
  $('#lightboxPrev')?.addEventListener('click', ()=>{ setMainImage(currentIndex-1); lbImg.src=imagesData[currentIndex]; });
  $('#lightboxNext')?.addEventListener('click', ()=>{ setMainImage(currentIndex+1); lbImg.src=imagesData[currentIndex]; });
  lb?.addEventListener('click', e=>{ if(e.target===lb) closeLb(); });
  document.addEventListener('keydown', e=>{
    if(!lb.classList.contains('active')) return;
    if(e.key==='Escape') closeLb();
    if(e.key==='ArrowLeft'){ setMainImage(currentIndex-1); lbImg.src=imagesData[currentIndex]; }
    if(e.key==='ArrowRight'){ setMainImage(currentIndex+1); lbImg.src=imagesData[currentIndex]; }
  });
  let lbSx=0;
  lb?.addEventListener('touchstart', e=>{ lbSx=e.touches[0].clientX; }, {passive:true});
  lb?.addEventListener('touchend', e=>{ const dx=e.changedTouches[0].clientX-lbSx; if(Math.abs(dx)>40){ setMainImage(dx>0?currentIndex-1:currentIndex+1); lbImg.src=imagesData[currentIndex]; } }, {passive:true});

  // Qty
  const qtyInput = $('#qtyInput');
  $('#qtyMinus')?.addEventListener('click', ()=>{ let v=parseInt(qtyInput.value)||1; if(v>1) qtyInput.value=v-1; });
  $('#qtyPlus')?.addEventListener('click', ()=>{ let v=parseInt(qtyInput.value)||1; qtyInput.value=v+1; });

  // Countdown for urgency - fixes ghosting
  (function(){ let h=2,m=14,s=33; const el=$('#countdown'); if(!el) return; setInterval(()=>{ s--; if(s<0){s=59;m--; if(m<0){m=59;h--; if(h<0)h=2;}} el.textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0'); },1000); })();

  // View count random
  (function(){ const el=$('#viewCount'); if(!el) return; setInterval(()=>{ el.textContent = Math.floor(18+Math.random()*15); }, 4000); })();

  // Sticky buy - appears after scroll 60% - fixes social bounce
  (function(){
    const sticky = $('#stickyBuy');
    if(!sticky) return;
    let shown=false;
    window.addEventListener('scroll', ()=>{
      if(window.scrollY > 400 && !shown){ sticky.classList.add('show'); shown=true; }
      if(window.scrollY < 200 && shown){ sticky.classList.remove('show'); shown=false; }
    }, {passive:true});
    $('#stickyBuyBtn')?.addEventListener('click', ()=> $('#buyNowBtn')?.click());
  })();

  // Pixel - guarded, no errors
  setTimeout(()=>{
    try{
      const eid='<%= typeof metaEventIdView !== "undefined" ? metaEventIdView : "" %>';
      const pname='<%- (product.name || "").replace(/'/g, "\\'") %>';
      const pid='<%= product._id %>';
      const pprice=<%= product.price || 0 %>;
      if(typeof fbq!=='undefined' && eid){
        fbq('track','ViewContent',{ content_name:pname, content_ids:[pid], content_type:'product', value:pprice, currency:'DZD', contents:[{id:pid, quantity:1, item_price:pprice}] },{eventID:eid});
      }
    }catch(e){ console.warn('fbq error', e); }
  },2000);

  // Buy Now - guarded
  const buyBtn = $('#buyNowBtn');
  if(buyBtn){
    buyBtn.addEventListener('click', function(e){
      try{
        e.preventDefault();
        const qty = parseInt($('#qtyInput')?.value)||1;
        this.disabled=true; this.textContent='جاري الإضافة…';
        const eid='<%= typeof metaEventIdCart !== "undefined" ? metaEventIdCart : "" %>';
        const pname='<%- (product.name || "").replace(/'/g, "\\'") %>';
        const pid='<%= product._id %>';
        const pprice=<%= product.price || 0 %>;
        if(typeof fbq!=='undefined' && eid){
          fbq('track','AddToCart',{ content_name:pname, content_ids:[pid], content_type:'product', value:pprice*qty, currency:'DZD', contents:[{id:pid, quantity:qty, item_price:pprice}] },{eventID:eid});
        }
        setTimeout(()=>{ window.location.href='/products/add-to-cart/'+pid+'?qty='+qty+'&eventId='+encodeURIComponent(eid); },150);
      }catch(err){ console.error(err); window.location.href='/products/add-to-cart/<%= product._id %>'; }
    });
  }
})();
</script>

<%- include('../../partials/footer') %>
