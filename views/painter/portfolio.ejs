
<%- include('../partials/header', { 
    title: 'Portfolio - Paintello Pro',
    user: painter,
    painter: painter 
}) %>

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-images me-2"></i>My Portfolio
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Instructions for Painters -->
                    <div class="alert alert-info mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-info-circle fa-2x me-3"></i>
                            <div>
                                <h5 class="alert-heading mb-1">How to Add Portfolio Images</h5>
                                <p class="mb-0">
                                    To showcase your work, send your best project photos via WhatsApp. 
                                    We'll upload them to our professional gallery and add them to your portfolio.
                                </p>
                            </div>
                        </div>
                    </div>

                    <% if (painter.portfolio.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-images fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">No portfolio items yet</h4>
                        <p class="text-muted">Contact us via WhatsApp to add your work photos</p>
                        <div class="mt-3">
                            <a href="https://wa.me/1234567890?text=Hello! I'd like to add photos to my Paintello Pro portfolio. My painter ID is: <%= painter._id %>" 
                               class="btn btn-success" target="_blank">
                                <i class="fab fa-whatsapp me-2"></i>Contact via WhatsApp
                            </a>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="row">
                        <% painter.portfolio.forEach((work, index) => { %>
                        <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                            <div class="card card-hover shadow-sm">
                                <div class="portfolio-image-container" style="height: 200px; overflow: hidden;">
                                    <img src="<%= work.flickrUrl %>" class="card-img-top" alt="Portfolio work"
                                         style="width: 100%; height: 100%; object-fit: cover;"
                                         onerror="this.src='https://via.placeholder.com/300x200/f8f9fa/6c757d?text=Image+Not+Found'">
                                </div>
                                <div class="card-body">
                                    <% if (work.description) { %>
                                    <p class="card-text small text-muted"><%= work.description %></p>
                                    <% } %>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            <i class="fas fa-calendar me-1"></i>
                                            <%= work.uploadedAt ? new Date(work.uploadedAt).toLocaleDateString() : 'Recently added' %>
                                        </small>
                                        <% if (work.uploadedByAdmin) { %>
                                        <span class="badge bg-info small">By Admin</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Portfolio Statistics -->
            <% if (painter.portfolio.length > 0) { %>
            <div class="row mt-4">
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h3 class="text-primary"><%= painter.portfolio.length %></h3>
                            <p class="text-muted mb-0">Total Projects</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h3 class="text-success">
                                <%= painter.portfolio.filter(p => p.uploadedByAdmin).length %>
                            </h3>
                            <p class="text-muted mb-0">Verified Photos</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h3 class="text-warning">
                                <%= new Date().getFullYear() %>
                            </h3>
                            <p class="text-muted mb-0">Active Year</p>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Contact Information Card -->
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fas fa-question-circle me-2"></i>Need More Portfolio Photos?
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-primary">
                                <i class="fab fa-whatsapp me-2"></i>Via WhatsApp
                            </h6>
                            <p class="small text-muted">
                                Send your best work photos with project descriptions. 
                                We'll professionally upload and add them within 24 hours.
                            </p>
                            <a href="https://wa.me/1234567890?text=Hello! I'd like to add portfolio photos. My Painter ID: <%= painter._id %>" 
                               class="btn btn-success btn-sm" target="_blank">
                                <i class="fab fa-whatsapp me-1"></i>Send Photos
                            </a>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-primary">
                                <i class="fas fa-phone me-2"></i>Via Phone
                            </h6>
                            <p class="small text-muted">
                                Call us to discuss your portfolio and we'll guide you 
                                through the process of showcasing your work.
                            </p>
                            <a href="tel:+1234567890" class="btn btn-primary btn-sm">
                                <i class="fas fa-phone me-1"></i>Call Now
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.portfolio-image-container {
    position: relative;
    background: #f8f9fa;
}

.portfolio-image-container img {
    transition: transform 0.3s ease;
}

.card-hover:hover .portfolio-image-container img {
    transform: scale(1.05);
}

.card-hover {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}
</style>

<%- include('../partials/footer') %>
