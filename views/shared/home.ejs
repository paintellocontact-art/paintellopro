<!-- ===== FEATURED PAINTERS ===== -->
<section class="featured-section">
    <div class="section-header-with-link">
        <div>
            <h2>Featured Painters</h2>
            <p>Top-rated professionals in your area</p>
        </div>
        <a href="/painters" class="view-all-link">
            View All Painters <i class="fas fa-arrow-right"></i>
        </a>
    </div>

    <div class="painters-grid-home">
        <% featuredPainters.forEach(painter => { %>
        <div class="painter-card-home" onclick="window.location.href='/painters/<%= painter._id %>'">
            <div class="card-body-home">
                <div class="avatar-home">
                    <% if (painter.profilePicture && painter.profilePicture.url) { %>
                        <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>">
                    <% } else { %>
                        <img src="https://placehold.co/200x200/295797/white?text=P" alt="<%= painter.name %>">
                    <% } %>
                    <% if (painter.verification?.status === 'verified') { %>
                        <div class="verified-badge-home">
                            <i class="fas fa-check"></i>
                        </div>
                    <% } %>
                </div>
                <div class="painter-name-home"><%= painter.name %></div>
                <div class="painter-location-home">
                    <i class="fas fa-map-marker-alt"></i> <%= painter.location?.wilaya || 'Algeria' %>
                </div>
                <div class="stats-home">
                    <div class="stat-home">
                        <span class="stat-value-home"><%= painter.completedJobs || 0 %></span>
                        <span class="stat-label-home">Jobs</span>
                    </div>
                    <div class="stat-home">
                        <span class="stat-value-home"><%= painter.experience || 0 %></span>
                        <span class="stat-label-home">Years</span>
                    </div>
                </div>
                <div class="rating-home">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star <%= i <= Math.round(painter.rating || 0) ? 'text-warning' : 'text-muted' %>"></i>
                    <% } %>
                    <span style="font-size: 0.75rem; color: var(--text-gray); margin-left: 4px;">(<%= (painter.rating || 0).toFixed(1) %>)</span>
                </div>
                <div class="price-home">
                    <%= painter.pricePerSqm || 0 %> DA/m²
                </div>
                <button class="btn-profile-home" onclick="event.stopPropagation(); window.location.href='/painters/<%= painter._id %>'">
                    View Profile
                </button>
            </div>
        </div>
        <% }); %>
    </div>
</section>

